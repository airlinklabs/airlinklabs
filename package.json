{
  "name": "airlink-site",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "tsx src/scripts/build.ts && npm run tw",
    "tw": "npx @tailwindcss/cli -i src/input.css -o dist/public/css/styles.css --minify",
    "tw:watch": "npx @tailwindcss/cli -i src/input.css -o dist/public/css/styles.css --watch",
    "dev": "tsx src/scripts/dev.ts",
    "cache": "tsx src/scripts/cache-github.ts"
  },
  "dependencies": {
    "@tailwindcss/cli": "^4.1.0",
    "tailwindcss": "^4.1.0",
    "ejs": "^3.1.10",
    "front-matter": "^4.0.2",
    "marked": "^12.0.0",
    "fs-extra": "^11.2.0"
  },
  "devDependencies": {
    "@types/ejs": "^3.1.5",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  },
  "site": {
    "title": "AirLink",
    "description": "Open-source game server management panel. Built with TypeScript, runs on your hardware.",
    "versionLabel": "v2.0.0-rc1",
    "githubOrg": "AirlinkLabs",
    "githubPanel": "AirlinkLabs/panel",
    "githubDaemon": "AirlinkLabs/daemon",
    "discordUrl": "https://discord.gg/D8YbT9rDqz",
    "installVideoUrl": ""
  },
  "underConstruction": {
    "enabled": false,
    "message": "The site is currently being updated.",
    "badge": "Under Construction"
  }
}
