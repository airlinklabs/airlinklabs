<script>
(function() {
  var overlay   = document.getElementById('feat-overlay');
  var modal     = document.getElementById('feat-modal');
  var iconEl    = document.getElementById('feat-modal-icon');
  var titleEl   = document.getElementById('feat-modal-title');
  var descEl    = document.getElementById('feat-modal-desc');
  var longEl    = document.getElementById('feat-modal-long');
  var closeBtn  = document.getElementById('feat-modal-close');
  var gifImg    = document.getElementById('feat-modal-gif');
  var gifPh     = document.getElementById('feat-modal-gif-ph');
  var gifLabel  = document.getElementById('feat-modal-gif-label');
  var EASE      = 'cubic-bezier(0.4,0,0.2,1)';

  var iconMap = {};
  <% features.forEach(function(f) { %>iconMap['<%= f.id %>'] = '<%- featureIcon(f.icon).replace(/\\/g,'\\\\').replace(/'/g,"\\'").replace(/\n/g,'') %>';<% }) %>

  function openModal(card) {
    var id = card.dataset.featureId || '';
    iconEl.innerHTML    = iconMap[id] || '';
    titleEl.textContent = card.dataset.featureTitle || '';
    descEl.textContent  = card.dataset.featureDesc  || '';
    longEl.textContent  = card.dataset.featureLong  || '';

    // Load theme-aware GIF
    var theme  = document.documentElement.className === 'light' ? 'light' : 'dark';
    var gifSrc = 'public/assets/features/' + id + '/' + id + '-' + theme + '.png';
    gifImg.style.display = 'none';
    gifImg.style.opacity = '0';
    gifPh.style.display  = 'flex';
    if (gifLabel) gifLabel.textContent = id + '-' + theme + '.png';
    gifImg.onerror = function() { gifImg.style.display = 'none'; gifPh.style.display = 'flex'; };
    gifImg.onload  = function() {
      gifImg.style.display    = 'block';
      gifPh.style.display     = 'none';
      gifImg.style.transition = 'opacity 280ms cubic-bezier(0.4,0,0.2,1)';
      void gifImg.offsetHeight;
      gifImg.style.opacity    = '1';
    };
    gifImg.src = gifSrc;

    overlay.style.transition    = 'opacity 220ms ' + EASE;
    overlay.style.opacity       = '1';
    overlay.style.pointerEvents = 'auto';
    modal.style.transition      = 'transform 220ms ' + EASE;
    modal.style.transform       = 'translateY(0)';
    if (typeof sounds !== 'undefined') sounds.play('modalOpen');
  }

  function closeModal() {
    overlay.style.opacity       = '0';
    overlay.style.pointerEvents = 'none';
    modal.style.transform       = 'translateY(14px)';
    if (typeof sounds !== 'undefined') sounds.play('modalClose');
  }

  document.querySelectorAll('[data-feature-id]').forEach(function(card) {
    card.addEventListener('click', function() { openModal(card); });
  });
  closeBtn.addEventListener('click', closeModal);
  overlay.addEventListener('click', function(e) { if (e.target === overlay) closeModal(); });
  document.addEventListener('keydown', function(e) { if (e.key === 'Escape') closeModal(); });
})();
</script>

<script>
(function() {
  var dotsEl   = document.getElementById('wiz-dots');
  var summaryEl = document.getElementById('wiz-summary');
  var labelEl  = document.getElementById('wiz-step-label');
  var titleEl  = document.getElementById('wiz-step-title');
  var bodyEl   = document.getElementById('wiz-step-body');
  var backBtn  = document.getElementById('wiz-back');
  var nextBtn  = document.getElementById('wiz-next');

  if (!dotsEl || !bodyEl) return;

  // Stored answers
  var ans = {
    mode:       'both',   // both | panel | daemon
    name:       'Airlink',
    port:       '3000',
    email:      '',
    user:       'admin',
    pass:       '',
    panelAddr:  '127.0.0.1',
    daemonPort: '3002',
    daemonKey:  '',
    addons:     [],       // ['modrinth', 'parachute']
  };

  // Step definitions — filtered dynamically based on mode
  function getSteps() {
    var steps = [ { id: 'mode' } ];
    if (ans.mode !== 'daemon') {
      steps.push({ id: 'panel-setup' });
      steps.push({ id: 'admin' });
    }
    if (ans.mode !== 'panel') {
      steps.push({ id: 'daemon-setup' });
    }
    if (ans.mode !== 'daemon') {
      steps.push({ id: 'addons' });
    }
    steps.push({ id: 'result' });
    return steps;
  }

  var isAnimating = false;

  function animateStepBody(direction, renderFn) {
    // direction: 1 = forward (slide left), -1 = back (slide right)
    if (isAnimating) {
      bodyEl.innerHTML = renderFn();
      return;
    }
    isAnimating = true;
    var EASE = 'cubic-bezier(0.4,0,0.2,1)';
    var outX = direction > 0 ? '-18px' : '18px';
    var inX  = direction > 0 ?  '18px' : '-18px';

    // Slide current content out
    bodyEl.style.transition = 'opacity 140ms ' + EASE + ', transform 140ms ' + EASE;
    bodyEl.style.opacity    = '0';
    bodyEl.style.transform  = 'translateX(' + outX + ')';

    setTimeout(function() {
      bodyEl.innerHTML        = renderFn();
      bodyEl.style.transition = 'none';
      bodyEl.style.opacity    = '0';
      bodyEl.style.transform  = 'translateX(' + inX + ')';
      void bodyEl.offsetHeight;
      bodyEl.style.transition = 'opacity 200ms ' + EASE + ', transform 200ms ' + EASE;
      bodyEl.style.opacity    = '1';
      bodyEl.style.transform  = 'translateX(0)';

      setTimeout(function() {
        bodyEl.style.transition = '';
        isAnimating = false;
        var firstInput = bodyEl.querySelector('input');
        if (firstInput) firstInput.focus();
      }, 210);
    }, 150);
  }

  function animateHeaderChange(labelText, titleText) {
    var EASE = 'cubic-bezier(0.4,0,0.2,1)';
    labelEl.style.transition = 'opacity 100ms ' + EASE;
    titleEl.style.transition = 'opacity 100ms ' + EASE;
    labelEl.style.opacity = '0';
    titleEl.style.opacity = '0';
    setTimeout(function() {
      labelEl.textContent = labelText;
      titleEl.textContent = titleText;
      labelEl.style.opacity = '1';
      titleEl.style.opacity = '1';
    }, 110);
  }

  function animateSummaryIn() {
    var EASE = 'cubic-bezier(0.4,0,0.2,1)';
    summaryEl.style.opacity   = '0';
    summaryEl.style.transform = 'translateY(-4px)';
    summaryEl.style.display   = 'block';
    void summaryEl.offsetHeight;
    summaryEl.style.transition = 'opacity 200ms ' + EASE + ', transform 200ms ' + EASE;
    summaryEl.style.opacity    = '1';
    summaryEl.style.transform  = 'translateY(0)';
  }

  function inputStyle() {
    return 'width:100%;box-sizing:border-box;background:var(--color-bg-input);border:1px solid var(--color-border-input);border-radius:8px;padding:10px 12px;font-size:13px;font-family:var(--font-mono);color:var(--color-text-1);outline:none;';
  }

  function textInput(id, type, val, ph) {
    return '<input id="' + id + '" type="' + type + '" value="' + val + '" placeholder="' + ph + '" style="' + inputStyle() + '" onfocus="this.style.borderColor=\'var(--color-text-4)\'" onblur="this.style.borderColor=\'var(--color-border-input)\'">'; 
  }

  function fieldGroup(fields) {
    // fields: [{label, input}] — renders as a clean vertical stack, no margin hacks
    var html = '<div style="display:flex;flex-direction:column;gap:14px;">';
    fields.forEach(function(f) {
      html += '<div>'
        + '<p style="font-size:10px;font-family:var(--font-mono);color:var(--color-text-3);text-transform:uppercase;letter-spacing:0.08em;margin:0 0 6px;">' + f.label + '</p>'
        + f.input
        + '</div>';
    });
    html += '</div>';
    return html;
  }

  function renderStep(stepId) {
    var html = '';

    if (stepId === 'mode') {
      html += '<p style="font-size:13px;color:var(--color-text-2);line-height:1.6;margin:0 0 14px;">The installer sets up Node.js, Docker, the panel, and optionally the daemon on your Linux server.</p>';
      html += '<div style="display:flex;flex-direction:column;gap:8px;">';
      var opts = [
        { val:'both',   label:'Panel + Daemon', desc:'Full setup — panel UI and the daemon that runs game containers.' },
        { val:'panel',  label:'Panel only',      desc:'Install the web panel. Add the daemon separately later.'        },
        { val:'daemon', label:'Daemon only',      desc:'Install the daemon on a node that already has a panel.'        },
      ];
      opts.forEach(function(o) {
        var active = ans.mode === o.val;
        html += '<div style="display:flex;align-items:flex-start;gap:12px;padding:11px 14px;border:1px solid '
          + (active ? 'var(--color-border-input)' : 'var(--color-border)')
          + ';border-radius:10px;background:'
          + (active ? 'var(--color-bg-hover)' : 'var(--color-bg)')
          + ';cursor:pointer;user-select:none;" onclick="wizModeChange(\'' + o.val + '\')">'
          + '<div style="width:16px;height:16px;border-radius:50%;border:1.5px solid '
          + (active ? 'var(--color-text-1)' : 'var(--color-text-4)')
          + ';display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:2px;background:'
          + (active ? 'var(--color-text-1)' : 'transparent') + ';">'
          + (active ? '<span style="width:6px;height:6px;border-radius:50%;background:var(--color-bg);display:block;"></span>' : '')
          + '</div>'
          + '<div><p style="font-size:13px;font-weight:600;color:var(--color-text-1);margin:0 0 2px;letter-spacing:-0.01em;">' + o.label + '</p>'
          + '<p style="font-size:11px;color:var(--color-text-3);margin:0;line-height:1.5;">' + o.desc + '</p></div>'
          + '</div>';
      });
      html += '</div>';

    } else if (stepId === 'panel-setup') {
      html += fieldGroup([
        { label: 'Panel name', input: textInput('wiz-name', 'text', ans.name, 'Airlink') },
        { label: 'Panel port', input: textInput('wiz-port', 'number', ans.port, '3000') },
      ]);

    } else if (stepId === 'admin') {
      html += '<p style="font-size:12px;color:var(--color-text-3);line-height:1.6;margin:0 0 14px;">First account becomes admin. Registration locks after setup.</p>';
      html += fieldGroup([
        { label: 'Email',    input: textInput('wiz-email', 'email',    ans.email, 'admin@example.com') },
        { label: 'Username', input: textInput('wiz-user',  'text',     ans.user,  'admin') },
        { label: 'Password', input: textInput('wiz-pass',  'password', ans.pass,  'min 8 chars · one letter · one number') },
      ]);

    } else if (stepId === 'daemon-setup') {
      html += '<p style="font-size:12px;color:var(--color-text-3);line-height:1.6;margin:0 0 14px;">Auth key comes from the panel after install — Nodes → create node.</p>';
      html += fieldGroup([
        { label: 'Panel address',  input: textInput('wiz-panel-addr',  'text',   ans.panelAddr,  '127.0.0.1 or your panel domain') },
        { label: 'Daemon port',    input: textInput('wiz-daemon-port', 'number', ans.daemonPort, '3002') },
        { label: 'Daemon auth key',input: textInput('wiz-daemon-key',  'text',   ans.daemonKey,  'from panel → Nodes') },
      ]);

    } else if (stepId === 'addons') {
      html += '<p style="font-size:12px;color:var(--color-text-3);line-height:1.6;margin:0 0 14px;">Optional — installed into the panel after the main setup completes.</p>';
      html += '<div style="display:flex;flex-direction:column;gap:8px;">';
      var addonsOpts = [
        { id:'modrinth',  name:'Modrinth Store', desc:'Browse and install Minecraft mods from Modrinth inside the panel.' },
        { id:'parachute', name:'Parachute',       desc:'Google Drive backups for your servers via OAuth.'                  },
      ];
      addonsOpts.forEach(function(a) {
        var on = ans.addons.indexOf(a.id) !== -1;
        html += '<div style="display:flex;align-items:flex-start;gap:12px;padding:11px 14px;border:1px solid '
          + (on ? 'var(--color-border-input)' : 'var(--color-border)')
          + ';border-radius:10px;background:'
          + (on ? 'var(--color-bg-hover)' : 'var(--color-bg)')
          + ';cursor:pointer;user-select:none;" onclick="wizToggleAddon(\'' + a.id + '\')">'
          + '<div style="width:14px;height:14px;border-radius:3px;border:1.5px solid '
          + (on ? 'var(--color-text-1)' : 'var(--color-text-4)')
          + ';display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:2px;background:'
          + (on ? 'var(--color-text-1)' : 'transparent') + ';">'
          + (on ? '<svg width="8" height="8" fill="none" stroke="var(--color-bg)" stroke-width="3" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>' : '')
          + '</div>'
          + '<div><p style="font-size:13px;font-weight:600;color:var(--color-text-1);margin:0 0 2px;letter-spacing:-0.01em;">' + a.name + '</p>'
          + '<p style="font-size:11px;color:var(--color-text-3);margin:0;line-height:1.5;">' + a.desc + '</p></div>'
          + '</div>';
      });
      html += '</div>';

    } else if (stepId === 'result') {
      var cmd = buildCommand();
      html += '<p style="font-size:12px;color:var(--color-text-3);margin:0 0 12px;">Run this as root on your server.</p>';
      html += '<div class="code-block" style="position:relative;background:var(--color-bg-input);border:1px solid var(--color-border);border-radius:9px;padding:14px 16px;">'
        + '<code id="inst-cmd" style="font-size:11px;color:var(--color-text-1);font-family:var(--font-mono);line-height:1.7;display:block;white-space:pre-wrap;word-break:break-all;padding-right:52px;">' + cmd + '</code>'
        + '<button class="copy-btn" style="position:absolute;top:10px;right:10px;font-size:10px;font-family:var(--font-mono);color:var(--color-text-3);background:var(--color-bg-2);border:1px solid var(--color-border);padding:5px 10px;border-radius:6px;display:flex;align-items:center;gap:4px;cursor:pointer;">'
        + '<svg width="10" height="10" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>'
        + 'Copy</button>'
        + '</div>';
    }

    return html;
  }

  function collectStep(stepId) {
    if (stepId === 'panel-setup') {
      var n = document.getElementById('wiz-name'); if (n) ans.name = n.value.trim() || 'Airlink';
      var p = document.getElementById('wiz-port'); if (p) ans.port = p.value.trim() || '3000';
    } else if (stepId === 'admin') {
      var e = document.getElementById('wiz-email'); if (e) ans.email = e.value.trim();
      var u = document.getElementById('wiz-user');  if (u) ans.user  = u.value.trim() || 'admin';
      var pw = document.getElementById('wiz-pass'); if (pw) ans.pass = pw.value.trim();
    } else if (stepId === 'daemon-setup') {
      var a = document.getElementById('wiz-panel-addr');  if (a)  ans.panelAddr  = a.value.trim()  || '127.0.0.1';
      var dp = document.getElementById('wiz-daemon-port'); if (dp) ans.daemonPort = dp.value.trim() || '3002';
      var dk = document.getElementById('wiz-daemon-key');  if (dk) ans.daemonKey  = dk.value.trim();
    }
  }

  var stepTitles = {
    'mode':         ['Step',    'What do you want to install?'],
    'panel-setup':  ['Panel',   'Name and port'],
    'admin':        ['Panel',   'Admin account'],
    'daemon-setup': ['Daemon',  'Connection settings'],
    'addons':       ['Addons',  'Any addons to include?'],
    'result':       ['Install', 'Your command'],
  };

  function summaryLine(label, val) {
    return '<span style="font-size:11px;font-family:var(--font-mono);color:var(--color-text-3);">' + label + '</span>'
         + '<span style="font-size:11px;font-family:var(--font-mono);color:var(--color-text-1);margin-left:8px;">' + (val || '—') + '</span>';
  }

  function renderSummary(steps, upToIndex) {
    if (upToIndex <= 0) { summaryEl.style.display = 'none'; return; }
    var lines = [];
    for (var i = 0; i < upToIndex; i++) {
      var sid = steps[i].id;
      if (sid === 'mode')         lines.push(summaryLine('Install', ans.mode === 'both' ? 'Panel + Daemon' : ans.mode === 'panel' ? 'Panel only' : 'Daemon only'));
      if (sid === 'panel-setup')  lines.push(summaryLine('Panel', ans.name + '  :' + ans.port));
      if (sid === 'admin')        lines.push(summaryLine('Admin', ans.email || ans.user));
      if (sid === 'daemon-setup') lines.push(summaryLine('Daemon', ans.panelAddr + '  :' + ans.daemonPort));
      if (sid === 'addons')       lines.push(summaryLine('Addons', ans.addons.length ? ans.addons.join(', ') : 'none'));
    }
    summaryEl.innerHTML = lines.join('<span style="color:var(--color-text-4);padding:0 10px;">·</span>');
    summaryEl.style.display = 'block';
  }

  function renderDots(steps, current) {
    dotsEl.innerHTML = '';
    steps.forEach(function(s, i) {
      var dot = document.createElement('span');
      dot.style.cssText = 'width:' + (i === current ? '20px' : '6px') + ';height:6px;border-radius:999px;background:' + (i <= current ? 'var(--color-text-1)' : 'var(--color-border-input)') + ';transition:all 200ms;display:inline-block;';
      dotsEl.appendChild(dot);
    });
  }

  function buildCommand() {
    var url  = 'https://raw.githubusercontent.com/airlinklabs/panel/refs/heads/main/installer.sh';
    var args = [];
    if (ans.mode === 'panel')  args.push('--panel-only');
    if (ans.mode === 'daemon') args.push('--daemon-only');
    if (ans.mode !== 'daemon') {
      if (ans.name  && ans.name  !== 'Airlink') args.push('--name "' + ans.name + '"');
      if (ans.port  && ans.port  !== '3000')    args.push('--port ' + ans.port);
      if (ans.email)                             args.push('--admin-email "' + ans.email + '"');
      if (ans.user  && ans.user  !== 'admin')    args.push('--admin-user "' + ans.user + '"');
      if (ans.pass)                              args.push('--admin-pass "' + ans.pass + '"');
    }
    if (ans.mode !== 'panel') {
      if (ans.panelAddr  && ans.panelAddr  !== '127.0.0.1') args.push('--panel-addr "' + ans.panelAddr + '"');
      if (ans.daemonPort && ans.daemonPort !== '3002')       args.push('--daemon-port ' + ans.daemonPort);
      if (ans.daemonKey)                                     args.push('--daemon-key "' + ans.daemonKey + '"');
    }
    if (ans.addons.length) args.push('--addons "' + ans.addons.join(',') + '"');
    var cmd = 'curl -sL ' + url + ' | bash -s --';
    if (args.length) cmd += ' \\\n  ' + args.join(' \\\n  ');
    return cmd;
  }

  var currentStep = 0;
  var stepDirection = 1; // 1 = forward, -1 = back

  function render() {
    var steps  = getSteps();
    var stepId = steps[currentStep].id;
    var meta   = stepTitles[stepId];

    renderDots(steps, currentStep);

    // Show summary bar from step 1 onward, but not on the result step
    if (currentStep > 0 && stepId !== 'result') {
      renderSummary(steps, currentStep);
      if (summaryEl.style.display === 'none' || !summaryEl.style.display) {
        animateSummaryIn();
      }
    } else {
      summaryEl.style.display = 'none';
    }

    animateHeaderChange(meta[0], meta[1]);
    animateStepBody(stepDirection, function() { return renderStep(stepId); });

    var isLast = currentStep === steps.length - 1;
    backBtn.style.display = currentStep > 0 ? '' : 'none';
    // Last step is result — hide Next, user copies from the code block
    nextBtn.style.display = isLast ? 'none' : '';
    if (!isLast) nextBtn.textContent = currentStep === steps.length - 2 ? 'Get command →' : 'Next →';


  }

  window.wizModeChange = function(val) {
    ans.mode = val;
    animateStepBody(0, function() { return renderStep('mode'); });
    if (typeof sounds !== 'undefined') sounds.play('select');
  };

  window.wizToggleAddon = function(id) {
    var idx = ans.addons.indexOf(id);
    if (idx === -1) ans.addons.push(id); else ans.addons.splice(idx, 1);
    animateStepBody(0, function() { return renderStep('addons'); });
    if (typeof sounds !== 'undefined') sounds.play('toggle');
  };

  nextBtn.addEventListener('click', function() {
    var steps  = getSteps();
    var stepId = steps[currentStep].id;
    collectStep(stepId);

    if (currentStep < steps.length - 1) {
      var isResultStep = steps[currentStep + 1].id === 'result';
      stepDirection = 1;
      currentStep++;
      render();
      if (typeof sounds !== 'undefined') sounds.play(isResultStep ? 'wizResult' : 'wizNext');
    }
  });

  backBtn.addEventListener('click', function() {
    var steps  = getSteps();
    collectStep(steps[currentStep].id);
    if (currentStep > 0) {
      stepDirection = -1;
      currentStep--;
      render();
      if (typeof sounds !== 'undefined') sounds.play('wizBack');
    }
  });

  document.addEventListener('keydown', function(e) {
    if (e.key === 'Enter' && document.getElementById('wiz-card') && bodyEl.contains(document.activeElement)) {
      e.preventDefault();
      nextBtn.click();
    }
  });

  render();
})();
</script>

<script>
// Image theme sync — dashboard screenshot + hero feature images
// Rules:
//   1. Show the variant that matches the current theme
//   2. If the theme variant failed to load, fall back to the other variant
//   3. If both failed, show the placeholder div
(function() {
  var dashDark  = document.getElementById('dashboard-img-dark');
  var dashLight = document.getElementById('dashboard-img-light');
  var dashPh    = document.getElementById('dashboard-ph');

  function imgFailed(el) { return el && el.dataset.failed === 'true'; }
  function imgLoaded(el) { return el && el.complete && el.naturalWidth > 0; }

  window.syncDashboard = function() {
    if (!dashDark && !dashLight) return;
    var isDark     = document.documentElement.className !== 'light';
    var wantEl     = isDark ? dashDark  : dashLight;
    var fallbackEl = isDark ? dashLight : dashDark;

    if (!imgFailed(wantEl) && imgLoaded(wantEl)) {
      if (wantEl)     wantEl.style.display     = '';
      if (fallbackEl) fallbackEl.style.display  = 'none';
      if (dashPh)     dashPh.style.display      = 'none';
    } else if (!imgFailed(fallbackEl) && imgLoaded(fallbackEl)) {
      if (wantEl)     wantEl.style.display     = 'none';
      if (fallbackEl) fallbackEl.style.display  = '';
      if (dashPh)     dashPh.style.display      = 'none';
    } else if (imgFailed(wantEl) && imgFailed(fallbackEl)) {
      if (wantEl)     wantEl.style.display     = 'none';
      if (fallbackEl) fallbackEl.style.display  = 'none';
      if (dashPh)     dashPh.style.display      = 'flex';
    }
    // else still loading — placeholder stays visible (it is the default)
  };

  function syncFeatureImages() {
    var isDark = document.documentElement.className !== 'light';

    document.querySelectorAll('.feat-gif-wrap').forEach(function(wrap) {
      var darkImg  = wrap.querySelector('.feat-gif-dark');
      var lightImg = wrap.querySelector('.feat-gif-light');
      var ph       = wrap.querySelector('.feat-gif-ph');

      var wantImg     = isDark ? darkImg  : lightImg;
      var fallbackImg = isDark ? lightImg : darkImg;

      if (wantImg && !imgFailed(wantImg) && imgLoaded(wantImg)) {
        wantImg.style.display     = '';
        if (fallbackImg) fallbackImg.style.display = 'none';
        if (ph)          ph.style.display           = 'none';
      } else if (fallbackImg && !imgFailed(fallbackImg) && imgLoaded(fallbackImg)) {
        if (wantImg)     wantImg.style.display     = 'none';
        fallbackImg.style.display = '';
        if (ph)          ph.style.display           = 'none';
      } else if ((!wantImg || imgFailed(wantImg)) && (!fallbackImg || imgFailed(fallbackImg))) {
        if (wantImg)     wantImg.style.display     = 'none';
        if (fallbackImg) fallbackImg.style.display  = 'none';
        if (ph)          ph.style.display           = 'flex';
      }
    });
  }

  window.featGifError = function(imgEl) {
    imgEl.dataset.failed = 'true';
    syncFeatureImages();
  };

  function syncAll() {
    window.syncDashboard();
    syncFeatureImages();
  }

  syncAll();
  var obs = new MutationObserver(syncAll);
  obs.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
})();
</script>

<script>
// Video walkthrough — desktop: always visible. Mobile: toggle show/hide.
(function() {
  var toggle  = document.getElementById('video-toggle');
  var body    = document.getElementById('video-body');
  var chevron = document.getElementById('video-chevron');
  var label   = document.getElementById('video-toggle-label');
  if (!body) return;

  var VIDEO_ID = (function() {
    var url = '<%= site.installVideoUrl || "" %>';
    var m = url.match(/(?:youtu\.be\/|youtube\.com\/(?:watch\?v=|embed\/|shorts\/))([A-Za-z0-9_-]{11})/);
    return m ? m[1] : '';
  })();

  if (!VIDEO_ID) return;

  // Inject the iframe once — it loads immediately on desktop, deferred on mobile
  function injectIframe() {
    if (body.querySelector('iframe')) return;
    var iframe = document.createElement('iframe');
    iframe.src = 'https://www.youtube.com/embed/' + VIDEO_ID + '?rel=0';
    iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share';
    iframe.allowFullscreen = true;
    iframe.referrerPolicy = 'strict-origin-when-cross-origin';
    iframe.style.cssText = 'width:100%;height:100%;border:none;display:block;';
    body.appendChild(iframe);
  }

  function isMobile() { return window.innerWidth <= 600; }

  function setupDesktop() {
    // Show toggle button: no. Show body: yes, always.
    if (toggle) toggle.style.display = 'none';
    body.style.display = 'block';
    injectIframe();
  }

  function setupMobile() {
    // Show toggle button, hide body by default
    if (toggle) toggle.style.display = 'flex';
    body.style.display = 'none';
    if (label) label.textContent = 'Watch the install walkthrough';
    if (chevron) chevron.style.transform = '';
  }

  // Initial setup
  if (isMobile()) {
    setupMobile();
  } else {
    setupDesktop();
  }

  // Toggle handler — mobile only
  if (toggle) {
    toggle.addEventListener('click', function() {
      if (!isMobile()) return;
      var isHidden = body.style.display === 'none';
      if (isHidden) {
        injectIframe();
        body.style.display = 'block';
        if (label)   label.textContent       = 'Hide walkthrough';
        if (chevron) chevron.style.transform  = 'rotate(180deg)';
        if (typeof sounds !== 'undefined') sounds.play('toggle');
      } else {
        body.style.display = 'none';
        if (label)   label.textContent       = 'Watch the install walkthrough';
        if (chevron) chevron.style.transform  = '';
        if (typeof sounds !== 'undefined') sounds.play('toggle');
      }
    });
  }

  // On resize, re-evaluate desktop vs mobile without page reload
  var lastMobile = isMobile();
  window.addEventListener('resize', function() {
    var nowMobile = isMobile();
    if (nowMobile === lastMobile) return;
    lastMobile = nowMobile;
    if (nowMobile) {
      setupMobile();
    } else {
      setupDesktop();
    }
  });
})();
</script>

<script>
// Team section — -_- scrolling background
(function() {
  var canvas = document.getElementById('team-canvas');
  if (!canvas) return;
  var ctx = canvas.getContext('2d');
  var TILE  = '-_-  ';
  var ANGLE = -12 * Math.PI / 180;
  var SPEED = 28;
  var FSZ   = 16;
  var LH    = Math.round(FSZ * 2.6);
  var off   = 0;
  var last  = null;

  function isDark() { return document.documentElement.className !== 'light'; }

  function resize() {
    canvas.width  = canvas.parentElement.offsetWidth  || window.innerWidth;
    canvas.height = canvas.parentElement.offsetHeight || window.innerHeight;
  }

  function draw(ts) {
    requestAnimationFrame(draw);
    if (last !== null) off += SPEED * (ts - last) / 1000;
    last = ts;
    var wrap = off % LH;
    var W = canvas.width;
    var H = canvas.height;
    ctx.clearRect(0, 0, W, H);
    ctx.save();
    ctx.translate(W / 2, H / 2);
    ctx.rotate(ANGLE);
    var D = Math.ceil(Math.sqrt(W * W + H * H));
    ctx.font = 'bold ' + FSZ + 'px monospace';
    ctx.fillStyle = isDark() ? 'rgba(255,255,255,0.07)' : 'rgba(0,0,0,0.07)';
    var tw  = ctx.measureText(TILE).width;
    var row = TILE.repeat(Math.ceil((D * 2) / tw) + 2);
    for (var y = -D - LH + wrap; y < D + LH; y += LH) ctx.fillText(row, -D, y);
    ctx.restore();
  }

  resize();
  window.addEventListener('resize', resize);
  requestAnimationFrame(draw);
})();
</script>

<script>
// ── Commit detail popup ───────────────────────────────────────────────────────
(function () {
  var overlay   = document.getElementById('commit-overlay');
  var modal     = document.getElementById('commit-modal');
  var closeBtn  = document.getElementById('cm-close');
  if (!overlay || !modal) return;

  var EASE = 'cubic-bezier(0.4,0,0.2,1)';

  function openCommit(data) {
    document.getElementById('cm-avatar').src   = data.avatar || '';
    document.getElementById('cm-author').textContent = data.author || '';
    document.getElementById('cm-date').textContent   = data.date ? new Date(data.date).toLocaleString() : '';
    document.getElementById('cm-message').textContent = data.msg || '';
    document.getElementById('cm-sha').textContent    = data.sha ? data.sha.slice(0,40) : '';
    document.getElementById('cm-repo').textContent   = data.repo || '';
    document.getElementById('cm-link').href          = data.url  || '#';
    overlay.style.opacity       = '1';
    overlay.style.pointerEvents = 'auto';
    modal.style.transform       = 'translateY(0) scale(1)';
    if (typeof sounds !== 'undefined') sounds.play('modalOpen');
  }

  function closeCommit() {
    overlay.style.opacity       = '0';
    overlay.style.pointerEvents = 'none';
    modal.style.transform       = 'translateY(10px) scale(0.97)';
    if (typeof sounds !== 'undefined') sounds.play('modalClose');
  }

  document.addEventListener('click', function (e) {
    var row = e.target.closest('.commit-row');
    if (!row) return;
    try { openCommit(JSON.parse(row.dataset.commit)); } catch (err) {}
  });

  closeBtn.addEventListener('click', closeCommit);
  overlay.addEventListener('click', function (e) { if (e.target === overlay) closeCommit(); });
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape' && overlay.style.pointerEvents === 'auto') closeCommit();
  });
})();

// ── Contributor profile popup ─────────────────────────────────────────────────
(function () {
  var overlay   = document.getElementById('contrib-overlay');
  var modal     = document.getElementById('contrib-modal');
  var closeBtn  = document.getElementById('cp-close');
  if (!overlay || !modal) return;

  function openContrib(data) {
    document.getElementById('cp-avatar').src           = data.avatar || '';
    document.getElementById('cp-name').textContent    = data.name   || data.login || '';
    document.getElementById('cp-login').textContent   = '@' + (data.login || '');
    document.getElementById('cp-company').textContent = data.company ? data.company.replace(/^@/, '') : '';
    document.getElementById('cp-bio').textContent     = data.bio    || '';
    document.getElementById('cp-commits').textContent = data.contributions || '0';
    document.getElementById('cp-link').href           = data.url    || '#';
    overlay.style.opacity       = '1';
    overlay.style.pointerEvents = 'auto';
    modal.style.transform       = 'translateY(0) scale(1)';
    if (typeof sounds !== 'undefined') sounds.play('modalOpen');
  }

  function closeContrib() {
    overlay.style.opacity       = '0';
    overlay.style.pointerEvents = 'none';
    modal.style.transform       = 'translateY(10px) scale(0.97)';
    if (typeof sounds !== 'undefined') sounds.play('modalClose');
  }

  document.addEventListener('click', function (e) {
    var row = e.target.closest('.contrib-row');
    if (!row) return;
    try { openContrib(JSON.parse(row.dataset.contrib)); } catch (err) {}
  });

  closeBtn.addEventListener('click', closeContrib);
  overlay.addEventListener('click', function (e) { if (e.target === overlay) closeContrib(); });
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape' && overlay.style.pointerEvents === 'auto') closeContrib();
  });
})();
</script>

