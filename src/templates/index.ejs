<%
const rootPrefix = '';
const pageTitle = null;
const pageDescription = site.description;
%>
<%- include('./partials/head', { site, underConstruction, rootPrefix, pageTitle, pageDescription }) %>
<%- include('./partials/nav', { site, underConstruction, rootPrefix, docPages, pageTitle }) %>

<style>
  /* On desktop the right strip is 52px. On mobile it's hidden (nav.ejs handles this).
     SPA sections need right padding to clear the strip on desktop. */
  .spa-section-inner {
    width: 100%;
    max-width: 1060px;
  }

  /* Hero layout */
  #hero-grid {
    display: flex;
    flex-direction: column;
    gap: clamp(28px, 4vw, 56px);
    width: 100%;
  }
  @media (min-width: 860px) {
    #hero-grid    { flex-direction: row; align-items: center; }
    #hero-left    { flex: 1; }
    #hero-mockup  { flex: 1; min-width: 0; }
  }

  /* ── Features ──────────────────────────────────────────────────── */

  /* Grid base — mobile first */
  #feat-list {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    overflow: hidden;
  }
  @media (min-width: 560px) { #feat-list { grid-template-columns: 1fr 1fr; } }
  @media (min-width: 900px) { #feat-list { grid-template-columns: 1fr 1fr 1fr; } }

  /* Hero cards — GIF fills the full column width at 16:9 */
  .feat-hero {
    flex-direction: column;
    padding: 0 !important;
    gap: 0 !important;
    overflow: hidden;
    cursor: pointer;
    background: var(--color-bg-2);
  }
  .feat-hero .feat-gif-wrap {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--color-bg-3);
    flex-shrink: 0;
    position: relative;
  }
  .feat-hero .feat-gif-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
    display: block;
  }
  /* Placeholder shown when GIF files are missing */
  .feat-gif-ph {
    position: absolute;
    inset: 0;
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 8px;
    font-size: 10px;
    font-family: var(--font-mono);
    color: var(--color-text-4);
    pointer-events: none;
  }
  .feat-gif-ph svg { width: 22px; height: 22px; }
  .feat-hero .feat-info {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 14px 18px;
  }

  /* 2-col: heroes span full width */
  @media (min-width: 560px) and (max-width: 899px) {
    .feat-hero { grid-column: 1 / -1; }
  }

  /* 3-col: one hero per column in first row.
     10 features = 3 heroes + 7 others. 7 in 3-col = 2 full rows + 1 leftover.
     Stretch the last regular card across 2 cols so the final row is filled. */
  @media (min-width: 900px) {
    .feat-hero { grid-column: span 1; }
    .feat-card:last-child { grid-column: span 2; }
  }

  /* Non-hero cards */
  .feat-card {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 16px 18px;
    background: var(--color-bg-2);
    cursor: pointer;
  }

  /* Mobile: hide desktop list, show square grid */
  #feat-list        { display: none; }
  #feat-mobile-grid { display: grid; }
  @media (min-width: 560px) {
    #feat-list        { display: grid; }
    #feat-mobile-grid { display: none; }
  }

  /* Mobile square grid */
  #feat-mobile-grid {
    grid-template-columns: repeat(4, 1fr);
    gap: 8px;
  }
  .feat-sq {
    aspect-ratio: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 6px;
    background: var(--color-bg-2);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    cursor: pointer;
    padding: 6px 4px;
    text-align: center;
    overflow: hidden;
  }
  .feat-sq span {
    font-size: 9px;
    font-family: var(--font-mono);
    color: var(--color-text-3);
    line-height: 1.2;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    width: 100%;
    text-align: center;
    padding: 0 2px;
  }

  /* Install wizard */
  #install-layout {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  #install-wizard {
    flex: 1;
    min-width: 0;
  }
  #install-video-col {
    flex: 1;
    min-width: 0;
  }
  @media (min-width: 860px) {
    #install-layout {
      flex-direction: row;
      align-items: flex-start;
    }
    #install-wizard    { max-width: 480px; }
    #install-video-col { position: sticky; top: 0; }
    /* Desktop: toggle button never shown, video body always shown */
    #video-toggle { display: none !important; }
    #video-body   { display: block !important; }
  }
  @media (max-width: 859px) {
    /* Mobile: show the toggle button */
    #video-toggle { display: flex !important; }
  }

  /* Activity */
  #activity-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(10px, 1.5vw, 14px);
    height: clamp(300px, 42vh, 420px);
  }
  @media (min-width: 700px) {
    #activity-grid { grid-template-columns: 1fr 1fr; }
  }

  /* Team */
  #team-featured {
    display: grid;
    grid-template-columns: 1fr;
    gap: 10px;
    margin-bottom: 12px;
  }
  @media (min-width: 540px) {
    #team-featured { grid-template-columns: repeat(3, 1fr); }
  }
  #team-others {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    overflow: hidden;
  }
  @media (min-width: 480px)  { #team-others { grid-template-columns: repeat(5, 1fr); } }
  @media (min-width: 700px)  { #team-others { grid-template-columns: repeat(7, 1fr); } }
  @media (min-width: 1000px) { #team-others { grid-template-columns: repeat(9, 1fr); } }

  /* SPA section base padding — desktop gets right clearance for floating pill nav (~60px) */
  .spa-section {
    padding: clamp(24px, 4vw, 52px) calc(60px + clamp(20px, 3vw, 48px)) clamp(24px, 4vw, 52px) clamp(20px, 3vw, 48px);
  }
</style>

<div id="spa-root" style="position:fixed;inset:0;overflow:hidden;background:var(--color-bg);overscroll-behavior:none;">

  <!-- ── 1: Hero ──────────────────────────────────────────────────── -->
  <section id="spa-hero" class="spa-section">
    <div class="spa-section-inner">

      <div id="hero-grid">
        <div id="hero-left">

          <div style="display:inline-flex;align-items:center;gap:6px;font-size:11px;font-family:var(--font-mono);color:var(--color-text-3);border:1px solid var(--color-border);background:var(--color-bg-2);padding:3px 11px;border-radius:999px;margin-bottom:clamp(16px,2.5vw,28px);">
            <span style="width:5px;height:5px;border-radius:50%;background:var(--color-success);flex-shrink:0;"></span>
            Open source &bull; MIT &bull; <%= site.versionLabel %>
          </div>

          <h1 style="font-size:clamp(28px,5vw,56px);font-weight:600;color:var(--color-text-1);line-height:1.06;letter-spacing:-0.04em;margin:0 0 clamp(12px,2vw,20px);">
            AirLink.
          </h1>

          <p style="font-size:clamp(13px,1.3vw,14px);color:var(--color-text-2);line-height:1.75;margin:0 0 clamp(18px,2.5vw,28px);max-width:400px;">
            Open-source game server panel built with TypeScript. Deploy across multiple nodes, control access with granular permissions, and extend everything through addons.
          </p>

          <div style="display:flex;flex-wrap:wrap;gap:9px;margin-bottom:clamp(14px,2vw,22px);">
            <a href="#spa-install" style="display:inline-flex;align-items:center;font-size:12px;font-weight:500;background:var(--color-text-1);color:var(--color-bg);padding:8px 20px;border-radius:999px;text-decoration:none;" onmouseover="this.style.opacity='.82'" onmouseout="this.style.opacity='1'">Get started</a>
            <a href="https://github.com/<%= site.githubPanel %>" target="_blank" rel="noopener"
              style="display:inline-flex;align-items:center;gap:7px;font-size:12px;font-weight:500;color:var(--color-text-2);border:1px solid var(--color-border);padding:8px 20px;border-radius:999px;text-decoration:none;"
              onmouseover="this.style.background='var(--color-bg-hover)';this.style.color='var(--color-text-1)';this.style.borderColor='var(--color-border-input)'"
              onmouseout="this.style.background='';this.style.color='var(--color-text-2)';this.style.borderColor='var(--color-border)'">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/></svg>
              Panel
            </a>
            <a href="https://github.com/<%= site.githubDaemon %>" target="_blank" rel="noopener"
              style="display:inline-flex;align-items:center;gap:7px;font-size:12px;font-weight:500;color:var(--color-text-2);border:1px solid var(--color-border);padding:8px 20px;border-radius:999px;text-decoration:none;"
              onmouseover="this.style.background='var(--color-bg-hover)';this.style.color='var(--color-text-1)';this.style.borderColor='var(--color-border-input)'"
              onmouseout="this.style.background='';this.style.color='var(--color-text-2)';this.style.borderColor='var(--color-border)'">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/></svg>
              Daemon
            </a>
          </div>

          <!-- Stat pills with SVG icons -->
          <div style="display:flex;flex-wrap:wrap;gap:8px;padding-top:clamp(14px,2vw,22px);border-top:1px solid var(--color-border);">

            <div style="display:inline-flex;align-items:center;gap:7px;border:1px solid var(--color-border);background:var(--color-bg-2);border-radius:999px;padding:6px 14px 6px 10px;">
              <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" style="color:var(--color-warning);flex-shrink:0;"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              <span style="font-size:12px;font-weight:600;color:var(--color-text-1);font-family:var(--font-mono);letter-spacing:-0.02em;"><%= (githubCache.stats&&githubCache.stats.totalStars) ? githubCache.stats.totalStars : '—' %></span>
              <span style="font-size:10px;color:var(--color-text-3);font-family:var(--font-mono);">stars</span>
            </div>

            <div style="display:inline-flex;align-items:center;gap:7px;border:1px solid var(--color-border);background:var(--color-bg-2);border-radius:999px;padding:6px 14px 6px 10px;">
              <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" style="color:var(--color-success);flex-shrink:0;"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>
              <span style="font-size:12px;font-weight:600;color:var(--color-text-1);font-family:var(--font-mono);letter-spacing:-0.02em;"><%= (githubCache.stats&&githubCache.stats.contributors) ? githubCache.stats.contributors : '—' %></span>
              <span style="font-size:10px;color:var(--color-text-3);font-family:var(--font-mono);">contributors</span>
            </div>

            <div style="display:inline-flex;align-items:center;gap:7px;border:1px solid var(--color-border);background:var(--color-bg-2);border-radius:999px;padding:6px 14px 6px 10px;">
              <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" style="color:var(--color-text-3);flex-shrink:0;"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
              <span style="font-size:12px;font-weight:600;color:var(--color-text-1);font-family:var(--font-mono);letter-spacing:-0.02em;">2</span>
              <span style="font-size:10px;color:var(--color-text-3);font-family:var(--font-mono);">repos</span>
            </div>

          </div>
        </div>

        <div id="hero-mockup"
          style="border-radius:12px;overflow:hidden;border:1px solid var(--color-border);background:var(--color-bg-2);aspect-ratio:16/10;"
          onmouseover="this.style.transform='translateY(-3px)';this.style.boxShadow='0 16px 40px rgba(0,0,0,0.18)'"
          onmouseout="this.style.transform='translateY(0)';this.style.boxShadow='none'">
          <div style="background:var(--color-bg-3);border-bottom:1px solid var(--color-border);padding:9px 12px;display:flex;align-items:center;gap:5px;">
            <span style="width:8px;height:8px;border-radius:50%;background:var(--color-danger);opacity:.55;"></span>
            <span style="width:8px;height:8px;border-radius:50%;background:var(--color-warning);opacity:.55;"></span>
            <span style="width:8px;height:8px;border-radius:50%;background:var(--color-success);opacity:.55;"></span>
            <div style="flex:1;height:14px;background:var(--color-bg-2);border:1px solid var(--color-border);border-radius:4px;margin-left:6px;"></div>
          </div>
          <div style="position:relative;width:100%;height:calc(100% - 39px);">
            <img id="dashboard-img-dark"  src="<%= rootPrefix %>public/assets/screenshots/dashboard-dark.png"  alt="AirLink dashboard" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:top;display:none;" onerror="this.dataset.failed='true'; syncDashboard()" onload="syncDashboard()">
            <img id="dashboard-img-light" src="<%= rootPrefix %>public/assets/screenshots/dashboard-light.png" alt="AirLink dashboard" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:top;display:none;" onerror="this.dataset.failed='true'; syncDashboard()" onload="syncDashboard()">
            <div id="dashboard-ph" style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:8px;color:var(--color-text-4);font-size:11px;font-family:var(--font-mono);text-align:center;">
              <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" style="opacity:.3;"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
              dashboard-dark.png / dashboard-light.png
            </div>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- ── 2: Features ──────────────────────────────────────────────── -->
  <section id="spa-features" class="spa-section" style="background:var(--color-bg-2);">
    <div class="spa-section-inner">

      <div style="margin-bottom:clamp(14px,1.8vw,24px);">
        <h2 style="font-size:clamp(18px,2.5vw,26px);font-weight:600;color:var(--color-text-1);letter-spacing:-0.03em;margin:0 0 4px;">Features</h2>
        <p style="font-size:12px;color:var(--color-text-3);margin:0;">Everything the panel and daemon ship with.</p>
      </div>

      <%
        var heroIds = ['server-management', 'console', 'file-manager'];
        var mobileShortNames = {
          'server-management': 'Servers',
          'console':           'Console',
          'file-manager':      'Files',
          'nodes':             'Nodes',
          'users':             'Users',
          'addons':            'Addons',
          'api':               'API',
          'sftp':              'SFTP',
          'migrations':        'Migrations',
          'pterodactyl-eggs':  'PT Eggs',
        };
      %>

      <!-- Desktop grid -->
      <div id="feat-list">
        <% features.forEach(function(f) {
             var isHero = heroIds.indexOf(f.id) !== -1;
        %>
        <div
          data-feature-id="<%= f.id %>"
          data-feature-title="<%= f.title %>"
          data-feature-desc="<%= f.description %>"
          data-feature-long="<%= f.longDescription %>"
          data-feature-icon="<%= f.icon %>"
          class="<%= isHero ? 'feat-hero' : 'feat-card' %>"
          onmouseover="this.querySelector('.feat-info')?this.querySelector('.feat-info').style.background='var(--color-bg-hover)':this.style.background='var(--color-bg-hover)'"
          onmouseout="this.querySelector('.feat-info')?this.querySelector('.feat-info').style.background='':this.style.background='var(--color-bg-2)'">

          <% if (isHero) { %>
          <!-- GIF strip — dark/light variants, placeholder shown when both fail -->
          <div class="feat-gif-wrap" data-feat-id="<%= f.id %>">
            <img class="feat-gif-dark"
              src="public/assets/features/<%= f.id %>/<%= f.id %>-dark.png"
              alt=""
              loading="lazy"
              onerror="this.dataset.failed='true'; featGifError(this)">
            <img class="feat-gif-light"
              src="public/assets/features/<%= f.id %>/<%= f.id %>-light.png"
              alt=""
              loading="lazy"
              style="display:none;"
              onerror="this.dataset.failed='true'; featGifError(this)">
            <div class="feat-gif-ph" style="display:none;">
              <div style="color:var(--color-text-3);opacity:0.35;"><%- featureIcon(f.icon) %></div>
              <span><%= f.id %>-[dark|light].png</span>
            </div>
          </div>
          <!-- Info row below GIF -->
          <div class="feat-info" style="background:var(--color-bg-2);">
            <div style="width:28px;height:28px;display:flex;align-items:center;justify-content:center;border:1px solid var(--color-border);border-radius:7px;background:var(--color-bg-3);color:var(--color-text-2);flex-shrink:0;margin-top:1px;">
              <%- featureIcon(f.icon) %>
            </div>
            <div style="flex:1;min-width:0;">
              <div style="display:flex;align-items:center;gap:8px;margin-bottom:3px;">
                <h3 style="font-size:12px;font-weight:600;color:var(--color-text-1);margin:0;letter-spacing:-0.01em;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"><%= f.title %></h3>
                <span style="font-size:9px;font-family:var(--font-mono);color:var(--color-text-3);background:var(--color-bg-3);border:1px solid var(--color-border);padding:1px 5px;border-radius:4px;flex-shrink:0;">core</span>
              </div>
              <p style="font-size:11px;color:var(--color-text-3);line-height:1.5;margin:0;"><%= f.description %></p>
            </div>
            <svg width="11" height="11" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="color:var(--color-text-4);flex-shrink:0;margin-top:3px;"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </div>

          <% } else { %>
          <!-- Normal row card -->
          <div style="width:28px;height:28px;display:flex;align-items:center;justify-content:center;border:1px solid var(--color-border);border-radius:7px;background:var(--color-bg-3);color:var(--color-text-2);flex-shrink:0;margin-top:1px;">
            <%- featureIcon(f.icon) %>
          </div>
          <div style="flex:1;min-width:0;">
            <div style="display:flex;align-items:center;gap:8px;margin-bottom:3px;">
              <h3 style="font-size:12px;font-weight:600;color:var(--color-text-1);margin:0;letter-spacing:-0.01em;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"><%= f.title %></h3>
              <% if (f.primary) { %>
              <span style="font-size:9px;font-family:var(--font-mono);color:var(--color-text-3);background:var(--color-bg-3);border:1px solid var(--color-border);padding:1px 5px;border-radius:4px;flex-shrink:0;">core</span>
              <% } %>
            </div>
            <p style="font-size:11px;color:var(--color-text-3);line-height:1.5;margin:0;"><%= f.description %></p>
          </div>
          <svg width="11" height="11" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="color:var(--color-text-4);flex-shrink:0;margin-top:3px;"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          <% } %>

        </div>
        <% }) %>
      </div>

      <!-- Mobile square grid -->
      <div id="feat-mobile-grid">
        <% features.forEach(function(f) { %>
        <div
          class="feat-sq"
          data-feature-id="<%= f.id %>"
          data-feature-title="<%= f.title %>"
          data-feature-desc="<%= f.description %>"
          data-feature-long="<%= f.longDescription %>"
          data-feature-icon="<%= f.icon %>"
          onmouseover="this.style.background='var(--color-bg-hover)';this.style.borderColor='var(--color-border-input)'"
          onmouseout="this.style.background='var(--color-bg-2)';this.style.borderColor='var(--color-border)'">
          <div style="color:var(--color-text-2);"><%- featureIcon(f.icon) %></div>
          <span><%= mobileShortNames[f.id] || f.title %></span>
        </div>
        <% }) %>
      </div>

    </div>
  </section>

  <!-- ── 3: Install ───────────────────────────────────────────────── -->
  <section id="spa-install" class="spa-section">
    <div class="spa-section-inner">

      <div style="margin-bottom:clamp(16px,2vw,28px);">
        <h2 style="font-size:clamp(18px,2.5vw,26px);font-weight:600;color:var(--color-text-1);letter-spacing:-0.03em;margin:0 0 4px;">Install</h2>
        <p style="font-size:12px;color:var(--color-text-3);margin:0;">Answer a few questions and copy the command.</p>
      </div>

      <div id="install-layout">

        <!-- Left / top: wizard -->
        <div id="install-wizard">

          <!-- Progress dots -->
          <div id="wiz-dots" style="display:flex;gap:6px;margin-bottom:20px;align-items:center;"></div>

          <!-- Summary of previous answers -->
          <div id="wiz-summary" style="display:none;margin-bottom:16px;padding:12px 14px;background:var(--color-bg-2);border:1px solid var(--color-border);border-radius:10px;"></div>

          <!-- Step card -->
          <div id="wiz-card" style="background:var(--color-bg-2);border:1px solid var(--color-border);border-radius:12px;overflow:hidden;">

            <div id="wiz-step-header" style="padding:16px 18px;border-bottom:1px solid var(--color-border);">
              <p id="wiz-step-label" style="font-size:10px;font-family:var(--font-mono);color:var(--color-text-3);text-transform:uppercase;letter-spacing:0.08em;margin:0 0 3px;"></p>
              <h3 id="wiz-step-title" style="font-size:15px;font-weight:600;color:var(--color-text-1);letter-spacing:-0.01em;margin:0;"></h3>
            </div>

            <div id="wiz-step-body" style="padding:18px;"></div>

            <div style="padding:14px 18px;border-top:1px solid var(--color-border);display:flex;align-items:center;justify-content:space-between;gap:10px;">
              <button id="wiz-back" type="button"
                style="font-size:12px;font-family:var(--font-mono);color:var(--color-text-3);background:transparent;border:1px solid var(--color-border);padding:8px 18px;border-radius:999px;cursor:pointer;display:none;"
                onmouseover="this.style.color='var(--color-text-1)';this.style.borderColor='var(--color-border-input)'"
                onmouseout="this.style.color='var(--color-text-3)';this.style.borderColor='var(--color-border)'">
                Back
              </button>
              <div></div>
              <button id="wiz-next" type="button"
                style="font-size:12px;font-weight:500;font-family:var(--font-mono);color:var(--color-bg);background:var(--color-text-1);border:none;padding:8px 22px;border-radius:999px;cursor:pointer;"
                onmouseover="this.style.opacity='0.82'" onmouseout="this.style.opacity='1'">
                Next →
              </button>
            </div>
          </div>

        </div>

        <!-- Right / bottom: video walkthrough -->
        <div id="install-video-col">

          <!-- Mobile-only toggle — hidden on desktop via CSS -->
          <button id="video-toggle"
            style="display:none;align-items:center;gap:8px;width:100%;background:transparent;border:1px solid var(--color-border);border-radius:10px;padding:11px 14px;cursor:pointer;text-align:left;margin-bottom:8px;"
            onmouseover="this.style.background='var(--color-bg-hover)';this.style.borderColor='var(--color-border-input)'"
            onmouseout="this.style.background='transparent';this.style.borderColor='var(--color-border)'">
            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24" style="color:var(--color-text-3);flex-shrink:0;"><circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8" fill="currentColor" stroke="none"/></svg>
            <span id="video-toggle-label" style="font-size:12px;font-weight:500;color:var(--color-text-2);flex:1;">Watch the install walkthrough</span>
            <svg id="video-chevron" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="color:var(--color-text-4);flex-shrink:0;"><polyline points="6 9 12 15 18 9"/></svg>
          </button>

          <!-- Video body — always visible on desktop, toggled on mobile -->
          <div id="video-body" style="border-radius:10px;overflow:hidden;border:1px solid var(--color-border);aspect-ratio:16/9;background:var(--color-bg-3);">
            <!-- iframe injected by JS -->
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ── 4: Activity ──────────────────────────────────────────────── -->
  <section id="spa-activity" class="spa-section" style="background:var(--color-bg-2);">
    <div class="spa-section-inner">

      <div style="margin-bottom:clamp(16px,2vw,24px);">
        <h2 style="font-size:clamp(18px,2.5vw,26px);font-weight:600;color:var(--color-text-1);letter-spacing:-0.03em;margin:0 0 4px;">Activity</h2>
        <p style="font-size:12px;color:var(--color-text-3);margin:0;">Recent commits and contributor breakdown across both repos.</p>
      </div>

      <%
        var _stats = githubCache.stats || {};
        var _versions = githubCache.versions || {};
      %>

      <!-- Stats bar -->
      <div style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:clamp(14px,2vw,20px);">
        <div style="display:inline-flex;align-items:center;gap:7px;border:1px solid var(--color-border);background:var(--color-bg);border-radius:10px;padding:8px 14px;">
          <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" style="color:var(--color-warning);flex-shrink:0;"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          <span style="font-size:13px;font-weight:600;color:var(--color-text-1);font-family:var(--font-mono);"><%- _stats.totalStars || '—' %></span>
          <span style="font-size:10px;color:var(--color-text-3);">stars</span>
        </div>
        <div style="display:inline-flex;align-items:center;gap:7px;border:1px solid var(--color-border);background:var(--color-bg);border-radius:10px;padding:8px 14px;">
          <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" style="color:var(--color-text-3);flex-shrink:0;"><path d="M7 18v-1a5 5 0 0 1 5-5 5 5 0 0 1 5 5v1"/><circle cx="12" cy="8" r="4"/><path d="M3 18v-1a3 3 0 0 1 3-3"/><circle cx="6" cy="10" r="2.5"/><path d="M21 18v-1a3 3 0 0 0-3-3"/><circle cx="18" cy="10" r="2.5"/></svg>
          <span style="font-size:13px;font-weight:600;color:var(--color-text-1);font-family:var(--font-mono);"><%- _stats.contributors || '—' %></span>
          <span style="font-size:10px;color:var(--color-text-3);">contributors</span>
        </div>
        <div style="display:inline-flex;align-items:center;gap:7px;border:1px solid var(--color-border);background:var(--color-bg);border-radius:10px;padding:8px 14px;">
          <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" style="color:var(--color-text-3);flex-shrink:0;"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
          <span style="font-size:13px;font-weight:600;color:var(--color-text-1);font-family:var(--font-mono);"><%- _stats.totalForks || '—' %></span>
          <span style="font-size:10px;color:var(--color-text-3);">forks</span>
        </div>
        <div style="display:inline-flex;align-items:center;gap:7px;border:1px solid var(--color-border);background:var(--color-bg);border-radius:10px;padding:8px 14px;">
          <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" style="color:var(--color-danger);flex-shrink:0;"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          <span style="font-size:13px;font-weight:600;color:var(--color-text-1);font-family:var(--font-mono);"><%- _stats.openIssues || '—' %></span>
          <span style="font-size:10px;color:var(--color-text-3);">open issues</span>
        </div>
        <% if (_versions.panelRelease) { %>
        <div style="display:inline-flex;align-items:center;gap:7px;border:1px solid var(--color-border);background:var(--color-bg);border-radius:10px;padding:8px 14px;">
          <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" style="color:var(--color-success);flex-shrink:0;"><polyline points="20 6 9 17 4 12"/></svg>
          <span style="font-size:13px;font-weight:600;color:var(--color-text-1);font-family:var(--font-mono);"><%- _versions.panelRelease %></span>
          <span style="font-size:10px;color:var(--color-text-3);">latest</span>
        </div>
        <% } %>
      </div>

      <%
        var allCommits = [];
        if (githubCache.panelCommits  && githubCache.panelCommits.length)  githubCache.panelCommits.slice(0,15).forEach(function(c)  { allCommits.push(Object.assign({},c,{_repo:'panel'})); });
        if (githubCache.daemonCommits && githubCache.daemonCommits.length) githubCache.daemonCommits.slice(0,15).forEach(function(c) { allCommits.push(Object.assign({},c,{_repo:'daemon'})); });
        allCommits.sort(function(a,b) { return new Date(b.commit.author.date) - new Date(a.commit.author.date); });

        // Build commit frequency data (commits per day, last 14 days)
        var freqMap = {};
        allCommits.forEach(function(c) {
          var d = c.commit.author.date.slice(0,10);
          freqMap[d] = (freqMap[d] || 0) + 1;
        });
        var freqDays = [];
        for (var i = 13; i >= 0; i--) {
          var dt = new Date(Date.now() - i * 86400000);
          var key = dt.toISOString().slice(0,10);
          freqDays.push({ date: key, count: freqMap[key] || 0 });
        }
        var freqMax = Math.max.apply(null, freqDays.map(function(d){ return d.count; })) || 1;

        function relativeDate(iso) {
          var diff = Date.now() - new Date(iso).getTime();
          var mins  = Math.floor(diff / 60000);
          var hours = Math.floor(mins  / 60);
          var days  = Math.floor(hours / 24);
          if (mins  < 60)  return mins  + 'm ago';
          if (hours < 24)  return hours + 'h ago';
          if (days  < 30)  return days  + 'd ago';
          return Math.floor(days / 30) + 'mo ago';
        }
      %>

      <!-- Commit frequency chart -->
      <div style="border:1px solid var(--color-border);border-radius:12px;overflow:hidden;margin-bottom:clamp(10px,1.5vw,14px);">
        <div style="padding:10px 14px;border-bottom:1px solid var(--color-border);background:var(--color-bg-3);display:flex;align-items:center;justify-content:space-between;">
          <span style="font-size:11px;font-family:var(--font-mono);font-weight:500;color:var(--color-text-2);">Commit frequency — last 14 days</span>
          <span style="font-size:10px;font-family:var(--font-mono);color:var(--color-text-3);"><%= allCommits.length %> commits cached</span>
        </div>
        <div style="padding:12px 14px 10px;background:var(--color-bg-2);">
          <div style="display:flex;align-items:flex-end;gap:3px;height:48px;">
            <% freqDays.forEach(function(day) { %>
            <%
              var pct = day.count === 0 ? 0 : Math.max(12, Math.round((day.count / freqMax) * 100));
              var label = day.date.slice(5);
            %>
            <div style="flex:1;display:flex;flex-direction:column;align-items:center;gap:3px;height:100%;">
              <div title="<%= label %>: <%= day.count %> commit<%= day.count !== 1 ? 's' : '' %>"
                style="width:100%;border-radius:3px 3px 0 0;background:<%= day.count > 0 ? 'var(--color-text-1)' : 'var(--color-border)' %>;opacity:<%= day.count > 0 ? '1' : '0.4' %>;margin-top:auto;height:<%= pct %>%;">
              </div>
            </div>
            <% }) %>
          </div>
          <div style="display:flex;justify-content:space-between;margin-top:5px;">
            <span style="font-size:9px;font-family:var(--font-mono);color:var(--color-text-4);"><%= freqDays[0].date.slice(5) %></span>
            <span style="font-size:9px;font-family:var(--font-mono);color:var(--color-text-4);">today</span>
          </div>
        </div>
      </div>

      <div id="activity-grid">

        <!-- Commits list -->
        <div style="border:1px solid var(--color-border);border-radius:12px;overflow:hidden;display:flex;flex-direction:column;">
          <div style="padding:10px 14px;border-bottom:1px solid var(--color-border);background:var(--color-bg-3);flex-shrink:0;">
            <span style="font-size:11px;font-family:var(--font-mono);font-weight:500;color:var(--color-text-2);">Recent commits</span>
          </div>
          <div style="flex:1;overflow-y:auto;background:var(--color-bg-2);">
            <% if (allCommits.length) { %>
              <% allCommits.slice(0,14).forEach(function(commit) { %>
              <div class="commit-row" data-commit='<%- JSON.stringify({sha:commit.sha,msg:commit.commit.message,author:commit.commit.author.name,date:commit.commit.author.date,avatar:commit.author?commit.author.avatar_url:"",repo:commit._repo,url:commit.html_url}).replace(/'/g,"&#39;") %>'
                style="display:flex;align-items:flex-start;gap:9px;padding:9px 14px;border-bottom:1px solid var(--color-border);cursor:pointer;"
                onmouseover="this.style.background='var(--color-bg-hover)'" onmouseout="this.style.background=''">
                <img src="<%= commit.author ? commit.author.avatar_url : '' %>" alt="" loading="lazy" style="width:18px;height:18px;border-radius:50%;flex-shrink:0;background:var(--color-bg-3);margin-top:1px;" onerror="this.style.display='none'">
                <div style="flex:1;min-width:0;">
                  <p style="font-size:11px;color:var(--color-text-1);margin:0 0 3px;line-height:1.4;overflow-wrap:break-word;word-break:break-word;"><%= commit.commit.message.split('\n')[0] %></p>
                  <div style="display:flex;align-items:center;gap:6px;flex-wrap:wrap;">
                    <span style="font-size:9px;color:var(--color-text-3);font-family:var(--font-mono);"><%= commit.commit.author.name %></span>
                    <span style="font-size:9px;font-family:var(--font-mono);color:var(--color-text-4);padding:0 4px;border:1px solid var(--color-border);border-radius:3px;"><%= commit._repo %></span>
                    <span style="font-size:9px;font-family:var(--font-mono);color:var(--color-text-4);"><%= relativeDate(commit.commit.author.date) %></span>
                  </div>
                </div>
                <span style="font-size:10px;font-family:var(--font-mono);color:var(--color-text-3);flex-shrink:0;"><%= commit.sha.slice(0,7) %></span>
              </div>
              <% }) %>
            <% } else { %>
            <div style="padding:24px;text-align:center;font-size:11px;font-family:var(--font-mono);color:var(--color-text-3);">No data. Run <code style="background:var(--color-bg-3);padding:1px 5px;border-radius:3px;">npm run cache</code></div>
            <% } %>
          </div>
        </div>

        <!-- Contributors list -->
        <div style="border:1px solid var(--color-border);border-radius:12px;overflow:hidden;display:flex;flex-direction:column;">
          <div style="padding:10px 14px;border-bottom:1px solid var(--color-border);background:var(--color-bg-3);flex-shrink:0;display:flex;justify-content:space-between;align-items:center;">
            <span style="font-size:11px;font-family:var(--font-mono);font-weight:500;color:var(--color-text-2);">Contributors</span>
            <span style="font-size:10px;font-family:var(--font-mono);color:var(--color-text-3);"><%= (_stats.contributors || 0) %> total</span>
          </div>
          <div style="flex:1;overflow-y:auto;background:var(--color-bg-2);">
            <% if (githubCache.contributors && githubCache.contributors.length) { %>
              <%
                var totalContribs = githubCache.contributors.reduce(function(s,c){ return s + (c.contributions||0); }, 0);
              %>
              <% githubCache.contributors.forEach(function(c, i) { %>
              <%
                var barPct = totalContribs > 0 ? Math.round((c.contributions / totalContribs) * 100) : 0;
              %>
              <div class="contrib-row" data-contrib='<%- JSON.stringify({login:c.login,name:c.name,bio:c.bio,company:c.company,avatar:c.avatar_url,url:c.html_url,contributions:c.contributions}).replace(/'/g,"&#39;") %>'
                style="display:flex;align-items:center;gap:9px;padding:8px 14px;border-bottom:1px solid var(--color-border);cursor:pointer;"
                onmouseover="this.style.background='var(--color-bg-hover)'" onmouseout="this.style.background=''">
                <img src="<%= c.avatar_url %>" alt="<%= c.login %>" loading="lazy"
                  style="width:<%= i===0?'22px':'17px' %>;height:<%= i===0?'22px':'17px' %>;border-radius:5px;border:1px solid var(--color-border);background:var(--color-bg-3);flex-shrink:0;">
                <div style="flex:1;min-width:0;">
                  <div style="display:flex;align-items:center;justify-content:space-between;gap:6px;margin-bottom:3px;">
                    <span style="font-size:<%= i===0?'12px':'11px' %>;font-weight:<%= i===0?'600':'500' %>;color:var(--color-text-1);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"><%= c.name || c.login %></span>
                    <span style="font-size:10px;font-family:var(--font-mono);color:var(--color-text-3);flex-shrink:0;"><%= c.contributions %></span>
                  </div>
                  <div style="height:2px;background:var(--color-border);border-radius:999px;overflow:hidden;">
                    <div style="height:100%;width:<%= barPct %>%;background:var(--color-text-1);border-radius:999px;opacity:0.5;"></div>
                  </div>
                </div>
              </div>
              <% }) %>
            <% } else { %>
            <div style="padding:24px;text-align:center;font-size:11px;font-family:var(--font-mono);color:var(--color-text-3);">No data. Run <code style="background:var(--color-bg-3);padding:1px 5px;border-radius:3px;">npm run cache</code></div>
            <% } %>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Commit detail popup -->
  <div id="commit-overlay" style="position:fixed;inset:0;background:rgba(0,0,0,0.55);z-index:300;display:flex;align-items:center;justify-content:center;padding:20px;opacity:0;pointer-events:none;transition:opacity 180ms cubic-bezier(0.4,0,0.2,1);">
    <div id="commit-modal" style="background:var(--color-bg-2);border:1px solid var(--color-border);border-radius:14px;max-width:480px;width:100%;padding:20px;transform:translateY(10px) scale(0.97);transition:transform 200ms cubic-bezier(0.34,1.1,0.64,1);">
      <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:12px;margin-bottom:14px;">
        <div style="display:flex;align-items:center;gap:9px;">
          <img id="cm-avatar" src="" alt="" loading="lazy" style="width:28px;height:28px;border-radius:50%;background:var(--color-bg-3);flex-shrink:0;" onerror="this.style.display='none'">
          <div>
            <p id="cm-author" style="font-size:12px;font-weight:600;color:var(--color-text-1);margin:0 0 2px;"></p>
            <p id="cm-date"   style="font-size:10px;font-family:var(--font-mono);color:var(--color-text-3);margin:0;"></p>
          </div>
        </div>
        <button id="cm-close" style="width:26px;height:26px;display:flex;align-items:center;justify-content:center;border:1px solid var(--color-border);border-radius:8px;color:var(--color-text-3);background:transparent;cursor:pointer;flex-shrink:0;" onmouseover="this.style.background='var(--color-bg-hover)'" onmouseout="this.style.background=''">
          <svg width="10" height="10" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18 6 6 18M6 6l12 12"/></svg>
        </button>
      </div>
      <p id="cm-message" style="font-size:13px;color:var(--color-text-1);line-height:1.6;margin:0 0 14px;overflow-wrap:break-word;word-break:break-word;"></p>
      <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
        <code id="cm-sha" style="font-size:11px;font-family:var(--font-mono);color:var(--color-text-3);background:var(--color-bg-3);border:1px solid var(--color-border);padding:2px 8px;border-radius:5px;"></code>
        <span id="cm-repo" style="font-size:10px;font-family:var(--font-mono);color:var(--color-text-4);padding:1px 6px;border:1px solid var(--color-border);border-radius:4px;"></span>
        <a id="cm-link" href="#" target="_blank" rel="noopener" style="font-size:11px;font-family:var(--font-mono);color:var(--color-text-3);text-decoration:none;margin-left:auto;" onmouseover="this.style.color='var(--color-text-1)'" onmouseout="this.style.color='var(--color-text-3)'">View on GitHub →</a>
      </div>
    </div>
  </div>

  <!-- Contributor profile popup -->
  <div id="contrib-overlay" style="position:fixed;inset:0;background:rgba(0,0,0,0.55);z-index:300;display:flex;align-items:center;justify-content:center;padding:20px;opacity:0;pointer-events:none;transition:opacity 180ms cubic-bezier(0.4,0,0.2,1);">
    <div id="contrib-modal" style="background:var(--color-bg-2);border:1px solid var(--color-border);border-radius:14px;max-width:360px;width:100%;padding:22px;transform:translateY(10px) scale(0.97);transition:transform 200ms cubic-bezier(0.34,1.1,0.64,1);">
      <div style="display:flex;align-items:flex-start;gap:14px;margin-bottom:16px;">
        <img id="cp-avatar" src="" alt="" loading="lazy" style="width:52px;height:52px;border-radius:12px;border:1px solid var(--color-border);background:var(--color-bg-3);flex-shrink:0;" onerror="this.style.background='var(--color-bg-3)'">
        <div style="flex:1;min-width:0;">
          <p id="cp-name"    style="font-size:15px;font-weight:600;color:var(--color-text-1);margin:0 0 2px;letter-spacing:-0.01em;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"></p>
          <p id="cp-login"   style="font-size:11px;font-family:var(--font-mono);color:var(--color-text-3);margin:0 0 4px;"></p>
          <p id="cp-company" style="font-size:11px;font-family:var(--font-mono);color:var(--color-text-4);margin:0;"></p>
        </div>
        <button id="cp-close" style="width:26px;height:26px;display:flex;align-items:center;justify-content:center;border:1px solid var(--color-border);border-radius:8px;color:var(--color-text-3);background:transparent;cursor:pointer;flex-shrink:0;" onmouseover="this.style.background='var(--color-bg-hover)'" onmouseout="this.style.background=''">
          <svg width="10" height="10" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18 6 6 18M6 6l12 12"/></svg>
        </button>
      </div>
      <p id="cp-bio" style="font-size:12px;color:var(--color-text-2);line-height:1.65;margin:0 0 14px;min-height:18px;"></p>
      <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;padding-top:14px;border-top:1px solid var(--color-border);">
        <div style="display:flex;align-items:center;gap:5px;">
          <svg width="11" height="11" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="color:var(--color-text-3);"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
          <span id="cp-commits" style="font-size:11px;font-family:var(--font-mono);color:var(--color-text-2);font-weight:600;"></span>
          <span style="font-size:11px;color:var(--color-text-3);">commits</span>
        </div>
        <a id="cp-link" href="#" target="_blank" rel="noopener" style="font-size:11px;font-family:var(--font-mono);color:var(--color-text-3);text-decoration:none;margin-left:auto;" onmouseover="this.style.color='var(--color-text-1)'" onmouseout="this.style.color='var(--color-text-3)'">View on GitHub →</a>
      </div>
    </div>
  </div>

  <!-- ── 5: Team ──────────────────────────────────────────────────── -->
  <section id="spa-team" class="spa-section" style="position:relative;overflow:hidden;">
    <canvas id="team-canvas" style="position:absolute;inset:0;width:100%;height:100%;pointer-events:none;z-index:0;" aria-hidden="true"></canvas>
    <div class="spa-section-inner" style="position:relative;z-index:1;">

      <div style="margin-bottom:clamp(16px,2vw,24px);">
        <h2 style="font-size:clamp(18px,2.5vw,26px);font-weight:600;color:var(--color-text-1);letter-spacing:-0.03em;margin:0 0 4px;">The team</h2>
        <p style="font-size:12px;color:var(--color-text-3);margin:0;">Everyone who contributed to the panel and daemon.</p>
      </div>

      <%
        var featuredMembers = [
          { login:'privt00',   role:'Lead',          fallbackName:'privt00'   },
          { login:'thavanish', role:'Maintainer',     fallbackName:'Thavanish' },
          { login:'achul123',  role:'Core Developer', fallbackName:'achul123'  },
        ];

        var contribLookup = {};
        if (githubCache.contributors && githubCache.contributors.length) {
          githubCache.contributors.forEach(function(c) {
            contribLookup[c.login.toLowerCase()] = c;
          });
        }
      %>

      <div id="team-featured">
        <% featuredMembers.forEach(function(m) {
             var cached      = contribLookup[m.login.toLowerCase()] || {};
             var displayName = (cached.name && cached.name !== m.login) ? cached.name : m.fallbackName;
             var bio         = cached.bio  || '';
             var company     = cached.company ? cached.company.replace(/^@/, '') : '';
             var contribs    = cached.contributions || null;
        %>
        <div class="contrib-row" data-contrib='<%- JSON.stringify({login:m.login,name:displayName,bio:bio,company:company,avatar:"https://github.com/"+m.login+".png",url:"https://github.com/"+m.login,contributions:contribs||0}).replace(/'/g,"&#39;") %>'
          style="display:flex;flex-direction:column;align-items:center;gap:10px;padding:clamp(14px,2vw,22px);border:1px solid var(--color-border);border-radius:12px;background:var(--color-bg-2);cursor:pointer;"
          onmouseover="this.style.background='var(--color-bg-hover)';this.style.borderColor='var(--color-border-input)';this.style.transform='translateY(-2px)'"
          onmouseout="this.style.background='var(--color-bg-2)';this.style.borderColor='var(--color-border)';this.style.transform=''">
          <img src="https://github.com/<%= m.login %>.png" alt="<%= displayName %>"
            loading="lazy"
            style="width:clamp(40px,5vw,52px);height:clamp(40px,5vw,52px);border-radius:10px;border:1px solid var(--color-border);background:var(--color-bg-3);"
            onerror="this.style.background='var(--color-bg-3)'">
          <div style="text-align:center;width:100%;">
            <p style="font-size:13px;font-weight:600;color:var(--color-text-1);margin:0 0 2px;letter-spacing:-0.01em;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"><%= displayName %></p>
            <p style="font-size:11px;font-family:var(--font-mono);color:var(--color-text-3);margin:0 0 5px;"><%= m.role %></p>
            <% if (bio) { %>
            <p style="font-size:10px;color:var(--color-text-3);line-height:1.45;margin:0 0 4px;overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;"><%= bio %></p>
            <% } %>
            <div style="display:flex;align-items:center;justify-content:center;gap:8px;flex-wrap:wrap;">
              <% if (company) { %>
              <span style="font-size:10px;font-family:var(--font-mono);color:var(--color-text-4);">@<%= company %></span>
              <% } %>
              <% if (contribs) { %>
              <span style="font-size:10px;font-family:var(--font-mono);color:var(--color-text-4);"><%= contribs %> commits</span>
              <% } %>
            </div>
          </div>
        </div>
        <% }) %>
      </div>

      <% if (githubCache.contributors && githubCache.contributors.length) { %>
        <% var fLogins = featuredMembers.map(function(f) { return f.login.toLowerCase(); }); %>
        <% var otherContributors = githubCache.contributors.filter(function(c) { return fLogins.indexOf(c.login.toLowerCase()) === -1; }); %>
        <% if (otherContributors.length) { %>
        <div id="team-others">
          <% otherContributors.forEach(function(c) { %>
          <div class="contrib-row" data-contrib='<%- JSON.stringify({login:c.login,name:c.name,bio:c.bio,company:c.company,avatar:c.avatar_url,url:c.html_url,contributions:c.contributions}).replace(/'/g,"&#39;") %>'
            title="<%= c.name || c.login %> — <%= c.contributions %> commits"
            style="display:flex;flex-direction:column;align-items:center;gap:5px;padding:10px 6px;background:var(--color-bg-2);cursor:pointer;"
            onmouseover="this.style.background='var(--color-bg-hover)'" onmouseout="this.style.background='var(--color-bg-2)'">
            <img src="<%= c.avatar_url %>" alt="<%= c.login %>"
              loading="lazy"
              style="width:28px;height:28px;border-radius:6px;border:1px solid var(--color-border);background:var(--color-bg-3);">
            <p style="font-size:9px;font-family:var(--font-mono);color:var(--color-text-3);margin:0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:100%;text-align:center;"><%= c.login %></p>
          </div>
          <% }) %>
        </div>
        <% } %>
      <% } %>

    </div>
  </section>

</div>

<!-- Feature detail modal -->
<div id="feat-overlay" style="position:fixed;inset:0;background:rgba(0,0,0,0.55);z-index:200;display:flex;align-items:center;justify-content:center;padding:20px;opacity:0;pointer-events:none;">
  <div id="feat-modal" style="background:var(--color-bg-2);border:1px solid var(--color-border);border-radius:14px;max-width:620px;width:100%;max-height:85vh;overflow-y:auto;transform:translateY(14px);">

    <!-- GIF preview -->
    <div id="feat-modal-media" style="aspect-ratio:16/9;background:var(--color-bg-3);border-radius:14px 14px 0 0;overflow:hidden;position:relative;border-bottom:1px solid var(--color-border);">
      <img id="feat-modal-gif" src="" alt="" style="width:100%;height:100%;object-fit:cover;object-position:top;display:none;">
      <div id="feat-modal-gif-ph" style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:8px;color:var(--color-text-4);font-size:11px;font-family:var(--font-mono);">
        <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" style="opacity:.3;"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
        <span id="feat-modal-gif-label" style="opacity:.4;"></span>
      </div>
    </div>

    <!-- Header -->
    <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:12px;padding:14px 18px;border-bottom:1px solid var(--color-border);">
      <div style="display:flex;align-items:center;gap:9px;">
        <div id="feat-modal-icon" style="width:26px;height:26px;display:flex;align-items:center;justify-content:center;border:1px solid var(--color-border);border-radius:8px;background:var(--color-bg-3);color:var(--color-text-2);flex-shrink:0;"></div>
        <h3 id="feat-modal-title" style="font-size:14px;font-weight:600;color:var(--color-text-1);letter-spacing:-0.01em;margin:0;"></h3>
      </div>
      <button id="feat-modal-close" style="width:26px;height:26px;display:flex;align-items:center;justify-content:center;border:1px solid var(--color-border);border-radius:8px;color:var(--color-text-3);background:transparent;cursor:pointer;flex-shrink:0;" onmouseover="this.style.background='var(--color-bg-hover)'" onmouseout="this.style.background=''">
        <svg width="10" height="10" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18 6 6 18M6 6l12 12"/></svg>
      </button>
    </div>

    <!-- Body -->
    <div style="padding:16px 18px;">
      <p id="feat-modal-desc" style="font-size:13px;color:var(--color-text-2);line-height:1.7;margin:0 0 8px;"></p>
      <p id="feat-modal-long" style="font-size:12px;color:var(--color-text-3);line-height:1.7;margin:0;"></p>
    </div>
  </div>
</div>

