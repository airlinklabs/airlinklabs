<script>
(function() {
  var overlay   = document.getElementById('feat-overlay');
  var modal     = document.getElementById('feat-modal');
  var iconEl    = document.getElementById('feat-modal-icon');
  var titleEl   = document.getElementById('feat-modal-title');
  var descEl    = document.getElementById('feat-modal-desc');
  var longEl    = document.getElementById('feat-modal-long');
  var closeBtn  = document.getElementById('feat-modal-close');
  var gifImg    = document.getElementById('feat-modal-gif');
  var gifPh     = document.getElementById('feat-modal-gif-ph');
  var gifLabel  = document.getElementById('feat-modal-gif-label');
  var EASE      = 'cubic-bezier(0.4,0,0.2,1)';

  var iconMap = {};
  <% features.forEach(function(f) { %>iconMap['<%= f.id %>'] = '<%- featureIcon(f.icon).replace(/\\/g,'\\\\').replace(/'/g,"\\'").replace(/\n/g,'') %>';<% }) %>

  function openModal(card) {
    var id = card.dataset.featureId || '';
    iconEl.innerHTML    = iconMap[id] || '';
    titleEl.textContent = card.dataset.featureTitle || '';
    descEl.textContent  = card.dataset.featureDesc  || '';
    longEl.textContent  = card.dataset.featureLong  || '';

    // Load theme-aware GIF
    var theme  = document.documentElement.className === 'light' ? 'light' : 'dark';
    var gifSrc = 'public/assets/features/' + id + '/' + id + '-' + theme + '.gif';
    gifImg.style.display = 'none';
    gifPh.style.display  = 'flex';
    if (gifLabel) gifLabel.textContent = id + '-' + theme + '.gif';
    gifImg.onerror = function() { gifImg.style.display = 'none'; gifPh.style.display = 'flex'; };
    gifImg.onload  = function() { gifImg.style.display = 'block'; gifPh.style.display = 'none'; };
    gifImg.src = gifSrc;

    overlay.style.transition    = 'opacity 220ms ' + EASE;
    overlay.style.opacity       = '1';
    overlay.style.pointerEvents = 'auto';
    modal.style.transition      = 'transform 220ms ' + EASE;
    modal.style.transform       = 'translateY(0)';
  }

  function closeModal() {
    overlay.style.opacity       = '0';
    overlay.style.pointerEvents = 'none';
    modal.style.transform       = 'translateY(14px)';
  }

  document.querySelectorAll('[data-feature-id]').forEach(function(card) {
    card.addEventListener('click', function() { openModal(card); });
  });
  closeBtn.addEventListener('click', closeModal);
  overlay.addEventListener('click', function(e) { if (e.target === overlay) closeModal(); });
  document.addEventListener('keydown', function(e) { if (e.key === 'Escape') closeModal(); });
})();
</script>

<script>
(function() {
  var dotsEl   = document.getElementById('wiz-dots');
  var summaryEl = document.getElementById('wiz-summary');
  var labelEl  = document.getElementById('wiz-step-label');
  var titleEl  = document.getElementById('wiz-step-title');
  var bodyEl   = document.getElementById('wiz-step-body');
  var backBtn  = document.getElementById('wiz-back');
  var nextBtn  = document.getElementById('wiz-next');
  var resultEl = document.getElementById('wiz-result');
  var cmdEl    = document.getElementById('inst-cmd');

  if (!dotsEl || !bodyEl || !cmdEl) return;

  // Stored answers
  var ans = {
    mode:       'both',   // both | panel | daemon
    name:       'Airlink',
    port:       '3000',
    email:      '',
    user:       'admin',
    pass:       '',
    panelAddr:  '127.0.0.1',
    daemonPort: '3002',
    daemonKey:  '',
    addons:     [],       // ['modrinth', 'parachute']
  };

  // Step definitions — filtered dynamically based on mode
  function getSteps() {
    var steps = [
      { id: 'mode' },
    ];
    if (ans.mode !== 'daemon') {
      steps.push({ id: 'panel-setup' });
      steps.push({ id: 'admin' });
    }
    if (ans.mode !== 'panel') {
      steps.push({ id: 'daemon-setup' });
    }
    steps.push({ id: 'addons' });
    return steps;
  }

  var currentStep = 0;

  function inputStyle() {
    return 'width:100%;box-sizing:border-box;background:var(--color-bg-input);border:1px solid var(--color-border-input);border-radius:8px;padding:10px 12px;font-size:14px;font-family:var(--font-mono);color:var(--color-text-1);outline:none;margin-top:6px;';
  }

  function labelStyle() {
    return 'display:block;font-size:10px;font-family:var(--font-mono);color:var(--color-text-3);text-transform:uppercase;letter-spacing:0.08em;margin-top:12px;';
  }

  function field(labelText, inputHtml) {
    return '<label style="' + labelStyle() + '">' + labelText + '</label>' + inputHtml;
  }

  function textInput(id, type, val, ph) {
    return '<input id="' + id + '" type="' + type + '" value="' + val + '" placeholder="' + ph + '" style="' + inputStyle() + '" onfocus="this.style.borderColor=\'var(--color-text-4)\'" onblur="this.style.borderColor=\'var(--color-border-input)\'">';
  }

  function renderStep(stepId) {
    var html = '';
    if (stepId === 'mode') {
      html = '<p style="font-size:13px;color:var(--color-text-2);line-height:1.6;margin:0 0 16px;">The installer sets up Node.js, Docker, the panel, and optionally the daemon on your Linux server.</p>';
      html += '<div style="display:flex;flex-direction:column;gap:8px;">';
      var opts = [
        { val:'both',   label:'Panel + Daemon', desc:'Full setup — panel UI and the daemon that runs game containers.' },
        { val:'panel',  label:'Panel only',      desc:'Install the web panel. Add the daemon separately later.'        },
        { val:'daemon', label:'Daemon only',      desc:'Install the daemon on a node that already has a panel.'        },
      ];
      opts.forEach(function(o) {
        var active = ans.mode === o.val;
        html += '<label style="display:flex;align-items:flex-start;gap:12px;padding:12px 14px;border:1px solid ' + (active ? 'var(--color-border-input)' : 'var(--color-border)') + ';border-radius:10px;background:' + (active ? 'var(--color-bg-hover)' : 'var(--color-bg)') + ';cursor:pointer;user-select:none;" onclick="document.querySelectorAll(\'[name=wiz-mode]\').forEach(function(r){r.checked=false});document.getElementById(\'wiz-mode-\'+\'' + o.val + '\').checked=true;wizModeChange(\'' + o.val + '\')">'
          + '<div style="width:16px;height:16px;border-radius:50%;border:1.5px solid ' + (active ? 'var(--color-text-1)' : 'var(--color-text-4)') + ';display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:2px;background:' + (active ? 'var(--color-text-1)' : 'transparent') + ';">'
          + (active ? '<span style="width:6px;height:6px;border-radius:50%;background:var(--color-bg);display:block;"></span>' : '')
          + '</div>'
          + '<div><p style="font-size:13px;font-weight:600;color:var(--color-text-1);margin:0 0 2px;letter-spacing:-0.01em;">' + o.label + '</p>'
          + '<p style="font-size:11px;color:var(--color-text-3);margin:0;line-height:1.5;">' + o.desc + '</p></div>'
          + '</label>';
      });
      html += '</div>';
    } else if (stepId === 'panel-setup') {
      html += field('Panel name', textInput('wiz-name', 'text', ans.name, 'Airlink'));
      html += field('Panel port', textInput('wiz-port', 'number', ans.port, '3000'));
    } else if (stepId === 'admin') {
      html += '<p style="font-size:12px;color:var(--color-text-3);margin:0 0 4px;line-height:1.6;">The first account created becomes the admin. Registration is disabled automatically after setup.</p>';
      html += field('Admin email', textInput('wiz-email', 'email', ans.email, 'admin@example.com'));
      html += field('Admin username', textInput('wiz-user', 'text', ans.user, 'admin'));
      html += field('Admin password', textInput('wiz-pass', 'password', ans.pass, 'min 8 chars, one letter + one number'));
    } else if (stepId === 'daemon-setup') {
      html += '<p style="font-size:12px;color:var(--color-text-3);margin:0 0 4px;line-height:1.6;">The daemon runs on the same machine or a separate node. The auth key comes from the panel\'s node setup page after the panel is installed.</p>';
      html += field('Panel address (for daemon to connect to)', textInput('wiz-panel-addr', 'text', ans.panelAddr, '127.0.0.1 or your panel domain'));
      html += field('Daemon port', textInput('wiz-daemon-port', 'number', ans.daemonPort, '3002'));
      html += field('Daemon auth key', textInput('wiz-daemon-key', 'text', ans.daemonKey, 'from panel → Nodes → create node'));
    } else if (stepId === 'addons') {
      html += '<p style="font-size:12px;color:var(--color-text-3);margin:0 0 16px;line-height:1.6;">Optional. These are installed into the panel after the main setup completes.</p>';
      html += '<div style="display:flex;flex-direction:column;gap:8px;">';
      var addonsOpts = [
        { id:'modrinth',  name:'Modrinth Store', desc:'Browse and install Minecraft mods from Modrinth inside the panel.' },
        { id:'parachute', name:'Parachute',       desc:'Google Drive backups for your servers via OAuth.'                  },
      ];
      addonsOpts.forEach(function(a) {
        var on = ans.addons.indexOf(a.id) !== -1;
        html += '<label style="display:flex;align-items:flex-start;gap:12px;padding:12px 14px;border:1px solid ' + (on ? 'var(--color-border-input)' : 'var(--color-border)') + ';border-radius:10px;background:' + (on ? 'var(--color-bg-hover)' : 'var(--color-bg)') + ';cursor:pointer;user-select:none;" onclick="wizToggleAddon(\'' + a.id + '\')">'
          + '<div style="width:14px;height:14px;border-radius:3px;border:1.5px solid ' + (on ? 'var(--color-text-1)' : 'var(--color-text-4)') + ';display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:2px;background:' + (on ? 'var(--color-text-1)' : 'transparent') + ';">'
          + (on ? '<svg width="8" height="8" fill="none" stroke="var(--color-bg)" stroke-width="3" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>' : '')
          + '</div>'
          + '<div><p style="font-size:13px;font-weight:600;color:var(--color-text-1);margin:0 0 2px;letter-spacing:-0.01em;">' + a.name + '</p>'
          + '<p style="font-size:11px;color:var(--color-text-3);margin:0;line-height:1.5;">' + a.desc + '</p></div>'
          + '</label>';
      });
      html += '</div>';
    }
    return html;
  }

  function collectStep(stepId) {
    if (stepId === 'panel-setup') {
      var n = document.getElementById('wiz-name'); if (n) ans.name = n.value.trim() || 'Airlink';
      var p = document.getElementById('wiz-port'); if (p) ans.port = p.value.trim() || '3000';
    } else if (stepId === 'admin') {
      var e = document.getElementById('wiz-email'); if (e) ans.email = e.value.trim();
      var u = document.getElementById('wiz-user');  if (u) ans.user  = u.value.trim() || 'admin';
      var pw = document.getElementById('wiz-pass'); if (pw) ans.pass = pw.value.trim();
    } else if (stepId === 'daemon-setup') {
      var a = document.getElementById('wiz-panel-addr');  if (a)  ans.panelAddr  = a.value.trim()  || '127.0.0.1';
      var dp = document.getElementById('wiz-daemon-port'); if (dp) ans.daemonPort = dp.value.trim() || '3002';
      var dk = document.getElementById('wiz-daemon-key');  if (dk) ans.daemonKey  = dk.value.trim();
    }
  }

  var stepTitles = {
    'mode':         ['Step',  'What do you want to install?'],
    'panel-setup':  ['Panel', 'Name and port'],
    'admin':        ['Panel', 'Admin account'],
    'daemon-setup': ['Daemon','Connection settings'],
    'addons':       ['Addons','Any addons to include?'],
  };

  function summaryLine(label, val) {
    return '<span style="font-size:11px;font-family:var(--font-mono);color:var(--color-text-3);">' + label + '</span>'
         + '<span style="font-size:11px;font-family:var(--font-mono);color:var(--color-text-1);margin-left:8px;">' + (val || '—') + '</span>';
  }

  function renderSummary(steps, upToIndex) {
    if (upToIndex <= 0) { summaryEl.style.display = 'none'; return; }
    var lines = [];
    for (var i = 0; i < upToIndex; i++) {
      var sid = steps[i].id;
      if (sid === 'mode')         lines.push(summaryLine('Install', ans.mode === 'both' ? 'Panel + Daemon' : ans.mode === 'panel' ? 'Panel only' : 'Daemon only'));
      if (sid === 'panel-setup')  lines.push(summaryLine('Panel', ans.name + '  :' + ans.port));
      if (sid === 'admin')        lines.push(summaryLine('Admin', ans.email || ans.user));
      if (sid === 'daemon-setup') lines.push(summaryLine('Daemon', ans.panelAddr + '  :' + ans.daemonPort));
      if (sid === 'addons')       lines.push(summaryLine('Addons', ans.addons.length ? ans.addons.join(', ') : 'none'));
    }
    summaryEl.innerHTML = lines.join('<span style="color:var(--color-text-4);padding:0 10px;">·</span>');
    summaryEl.style.display = 'block';
  }

  function renderDots(steps, current) {
    dotsEl.innerHTML = '';
    steps.forEach(function(s, i) {
      var dot = document.createElement('span');
      dot.style.cssText = 'width:' + (i === current ? '20px' : '6px') + ';height:6px;border-radius:999px;background:' + (i <= current ? 'var(--color-text-1)' : 'var(--color-border-input)') + ';transition:all 200ms;display:inline-block;';
      dotsEl.appendChild(dot);
    });
  }

  function buildCommand() {
    var url   = 'https://airlinklabs.github.io/home/installer.sh';
    var parts = ['bash <(curl -s ' + url + ')'];
    if (ans.mode === 'panel')  parts.push('  --panel-only');
    if (ans.mode === 'daemon') parts.push('  --daemon-only');
    if (ans.mode !== 'daemon') {
      if (ans.name  && ans.name  !== 'Airlink') parts.push('  --name "' + ans.name + '"');
      if (ans.port  && ans.port  !== '3000')    parts.push('  --port ' + ans.port);
      if (ans.email)                             parts.push('  --admin-email "' + ans.email + '"');
      if (ans.user  && ans.user  !== 'admin')    parts.push('  --admin-user "' + ans.user + '"');
      if (ans.pass)                              parts.push('  --admin-pass "' + ans.pass + '"');
    }
    if (ans.mode !== 'panel') {
      if (ans.panelAddr  && ans.panelAddr  !== '127.0.0.1') parts.push('  --panel-addr "' + ans.panelAddr + '"');
      if (ans.daemonPort && ans.daemonPort !== '3002')       parts.push('  --daemon-port ' + ans.daemonPort);
      if (ans.daemonKey)                                     parts.push('  --daemon-key "' + ans.daemonKey + '"');
    }
    if (ans.addons.length) parts.push('  --addons "' + ans.addons.join(',') + '"');
    cmdEl.textContent = parts.join(' \\\n');
  }

  function render() {
    var steps = getSteps();
    var stepId = steps[currentStep].id;
    var meta = stepTitles[stepId];

    renderDots(steps, currentStep);
    renderSummary(steps, currentStep);
    labelEl.textContent = meta[0];
    titleEl.textContent = meta[1];
    bodyEl.innerHTML = renderStep(stepId);

    var isLast = currentStep === steps.length - 1;
    backBtn.style.display = currentStep > 0 ? '' : 'none';
    nextBtn.textContent   = isLast ? 'Get command →' : 'Next →';

    // Focus first input in body
    var firstInput = bodyEl.querySelector('input');
    if (firstInput) setTimeout(function() { firstInput.focus(); }, 50);

    if (isLast) {
      buildCommand();
      resultEl.style.display = 'block';
    } else {
      resultEl.style.display = 'none';
    }
  }

  // Expose for inline onclick
  window.wizModeChange = function(val) {
    ans.mode = val;
    bodyEl.innerHTML = renderStep('mode');
    buildCommand();
  };

  window.wizToggleAddon = function(id) {
    var idx = ans.addons.indexOf(id);
    if (idx === -1) ans.addons.push(id); else ans.addons.splice(idx, 1);
    bodyEl.innerHTML = renderStep('addons');
    buildCommand();
  };

  nextBtn.addEventListener('click', function() {
    var steps  = getSteps();
    var stepId = steps[currentStep].id;
    collectStep(stepId);

    if (currentStep < steps.length - 1) {
      currentStep++;
      render();
    } else {
      buildCommand();
    }
  });

  backBtn.addEventListener('click', function() {
    var steps  = getSteps();
    var stepId = steps[currentStep].id;
    collectStep(stepId);
    if (currentStep > 0) { currentStep--; render(); }
  });

  // Enter key advances wizard
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Enter' && document.getElementById('wiz-card') && bodyEl.contains(document.activeElement)) {
      e.preventDefault();
      nextBtn.click();
    }
  });

  render();
})();
</script>

<script>
// Dashboard GIF — swap between dark and light variant when theme changes
(function() {
  var dark  = document.getElementById('dashboard-img-dark');
  var light = document.getElementById('dashboard-img-light');
  if (!dark || !light) return;

  function syncDashboard() {
    var isDark = document.documentElement.className !== 'light';
    dark.style.display  = isDark ? '' : 'none';
    light.style.display = isDark ? 'none' : '';
  }

  syncDashboard();

  // Watch for class changes on <html> (theme toggles)
  var obs = new MutationObserver(syncDashboard);
  obs.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
})();
</script>

<script>
// Team section — -_- scrolling background
(function() {
  var canvas = document.getElementById('team-canvas');
  if (!canvas) return;
  var ctx = canvas.getContext('2d');
  var TILE  = '-_-  ';
  var ANGLE = -12 * Math.PI / 180;
  var SPEED = 28;
  var FSZ   = 16;
  var LH    = Math.round(FSZ * 2.6);
  var off   = 0;
  var last  = null;

  function isDark() { return document.documentElement.className !== 'light'; }

  function resize() {
    canvas.width  = canvas.parentElement.offsetWidth  || window.innerWidth;
    canvas.height = canvas.parentElement.offsetHeight || window.innerHeight;
  }

  function draw(ts) {
    requestAnimationFrame(draw);
    if (last !== null) off += SPEED * (ts - last) / 1000;
    last = ts;
    var wrap = off % LH;
    var W = canvas.width;
    var H = canvas.height;
    ctx.clearRect(0, 0, W, H);
    ctx.save();
    ctx.translate(W / 2, H / 2);
    ctx.rotate(ANGLE);
    var D = Math.ceil(Math.sqrt(W * W + H * H));
    ctx.font = 'bold ' + FSZ + 'px monospace';
    ctx.fillStyle = isDark() ? 'rgba(255,255,255,0.07)' : 'rgba(0,0,0,0.07)';
    var tw  = ctx.measureText(TILE).width;
    var row = TILE.repeat(Math.ceil((D * 2) / tw) + 2);
    for (var y = -D - LH + wrap; y < D + LH; y += LH) ctx.fillText(row, -D, y);
    ctx.restore();
  }

  resize();
  window.addEventListener('resize', resize);
  requestAnimationFrame(draw);
})();
</script>

</body>
