<%
const rootPrefix = '../../';
const pageTitle = post.title;
const pageDescription = post.title + ' — ' + site.title + ' announcement.';

// rough reading time: ~200 words per minute
const wordCount = post.content.replace(/<[^>]+>/g, '').split(/\s+/).filter(Boolean).length;
const readMins  = Math.max(1, Math.round(wordCount / 200));
%>
<%- include('./partials/head', { site, underConstruction, rootPrefix, pageTitle, pageDescription }) %>
<%- include('./partials/nav', { site, underConstruction, rootPrefix, docPages, pageTitle }) %>

<div id="page-content">
  <div style="max-width:660px;">

    <div style="padding:clamp(32px,5vw,72px) 0 clamp(20px,3vw,36px);border-bottom:1px solid var(--color-border);margin-bottom:clamp(20px,3vw,36px);">

      <a href="<%= rootPrefix %>blog/index.html" class="post-back-link">
        <svg width="11" height="11" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
        Blog
      </a>

      <h1 style="font-size:clamp(20px,3.5vw,34px);font-weight:600;color:var(--color-text-1);letter-spacing:-0.03em;margin:0 0 16px;overflow-wrap:break-word;word-break:break-word;"><%= post.title %></h1>

      <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
        <% if (post.authorGithub) { %>
        <img src="https://github.com/<%= post.authorGithub %>.png?size=40" alt="" loading="lazy" style="width:22px;height:22px;border-radius:50%;background:var(--color-bg-3);flex-shrink:0;" onerror="this.style.display='none'">
        <% } %>
        <span style="font-size:12px;font-family:var(--font-mono);color:var(--color-text-2);">
          <%= post.author || 'AirlinkLabs' %>
        </span>
        <% if (post.date) { %>
        <span style="font-size:12px;font-family:var(--font-mono);color:var(--color-text-4);">·</span>
        <span style="font-size:12px;font-family:var(--font-mono);color:var(--color-text-3);"><%= post.date %></span>
        <% } %>
        <span style="font-size:12px;font-family:var(--font-mono);color:var(--color-text-4);">·</span>
        <span style="font-size:12px;font-family:var(--font-mono);color:var(--color-text-3);"><%= readMins %> min read</span>
      </div>

    </div>

    <article class="prose">
      <%- post.content %>
    </article>

    <div style="margin-top:clamp(32px,5vw,56px);padding-top:20px;border-top:1px solid var(--color-border);">
      <a href="<%= rootPrefix %>blog/index.html" class="post-back-link">
        <svg width="11" height="11" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
        All posts
      </a>
    </div>

  </div>
</div>

<script src="<%= rootPrefix %>public/js/main.js"></script>
</body>
</html>
