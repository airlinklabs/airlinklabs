<%
const rootPrefix = '../';
const pageTitle = 'Blog';
const pageDescription = 'Announcements and release notes from AirLink.';
%>
<%- include('./partials/head', { site, underConstruction, rootPrefix, pageTitle, pageDescription }) %>
<%- include('./partials/nav', { site, underConstruction, rootPrefix, docPages, pageTitle }) %>

<div id="page-content">
  <div style="max-width:680px;">

    <div id="blog-header">
      <p class="eyebrow">Announcements</p>
      <h1><%= site.title %> Blog</h1>
    </div>

    <% if (announcements && announcements.length) { %>

    <%
      var pinnedPosts  = announcements.filter(function(p) { return p.pinned; });
      var regularPosts = announcements.filter(function(p) { return !p.pinned; });
    %>

    <% if (pinnedPosts.length) { %>
    <div style="margin-bottom:clamp(20px,3vw,36px);">
      <p style="font-size:10px;font-family:var(--font-mono);color:var(--color-text-3);text-transform:uppercase;letter-spacing:0.1em;margin:0 0 12px;display:flex;align-items:center;gap:7px;">
        <svg width="10" height="10" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        Pinned
      </p>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(min(100%,260px),1fr));gap:12px;">
        <% pinnedPosts.forEach(function(post) { %>
        <a href="<%= rootPrefix %>blog/<%= post.slug %>/index.html" class="blog-card">
          <p class="post-title"><%= post.title %></p>
          <div style="display:flex;align-items:center;gap:8px;margin-top:auto;">
            <% if (post.authorGithub) { %>
            <img src="https://github.com/<%= post.authorGithub %>.png?size=32" alt="" loading="lazy" style="width:16px;height:16px;border-radius:50%;background:var(--color-bg-3);flex-shrink:0;" onerror="this.style.display='none'">
            <% } %>
            <span style="font-size:11px;font-family:var(--font-mono);color:var(--color-text-3);"><%= post.author || 'AirlinkLabs' %></span>
            <% if (post.date) { %>
            <span style="font-size:11px;font-family:var(--font-mono);color:var(--color-text-4);">· <%= post.date %></span>
            <% } %>
          </div>
        </a>
        <% }) %>
      </div>
    </div>
    <% } %>

    <% if (regularPosts.length) { %>
    <div>
      <% if (pinnedPosts.length) { %>
      <p style="font-size:10px;font-family:var(--font-mono);color:var(--color-text-3);text-transform:uppercase;letter-spacing:0.1em;margin:0 0 4px;">All posts</p>
      <% } %>
      <% regularPosts.forEach(function(post) { %>
      <a href="<%= rootPrefix %>blog/<%= post.slug %>/index.html" class="blog-post-row">
        <div style="min-width:0;">
          <p class="post-title"><%= post.title %></p>
          <div class="post-meta">
            <% if (post.authorGithub) { %>
            <img src="https://github.com/<%= post.authorGithub %>.png?size=28" alt="" loading="lazy" style="width:14px;height:14px;border-radius:50%;background:var(--color-bg-3);flex-shrink:0;" onerror="this.style.display='none'">
            <% } %>
            <span><%= post.author || 'AirlinkLabs' %></span>
          </div>
        </div>
        <div style="display:flex;align-items:center;gap:10px;flex-shrink:0;">
          <% if (post.date) { %>
          <span class="post-date"><%= post.date %></span>
          <% } %>
          <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="color:var(--color-text-4);flex-shrink:0;"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </div>
      </a>
      <% }) %>
    </div>
    <% } %>

    <% } else { %>
    <p style="font-size:13px;font-family:var(--font-mono);color:var(--color-text-3);padding:40px 0;">No posts yet.</p>
    <% } %>

  </div>
</div>

<script src="<%= rootPrefix %>public/js/main.js"></script>
</body>
</html>
