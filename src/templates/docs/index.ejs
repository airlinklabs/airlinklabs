<%
const rootPrefix = '../';
const pageTitle = 'Docs';
const pageDescription = 'AirLink Panel documentation.';
%>
<%- include('./partials/head', { site, underConstruction, rootPrefix, pageTitle, pageDescription }) %>
<%- include('./partials/nav', { site, underConstruction, rootPrefix, docPages, pageTitle }) %>

<div id="page-content" style="min-height:100vh;padding:clamp(32px,5vw,72px) clamp(72px,8vw,96px);box-sizing:border-box;max-width:820px;">

  <div style="padding:clamp(32px,6vw,80px) 0 clamp(20px,3vw,40px);border-bottom:1px solid var(--color-border);margin-bottom:clamp(24px,3vw,48px);">
    <p style="font-size:10px;font-family:var(--font-mono);color:var(--color-text-3);text-transform:uppercase;letter-spacing:0.1em;margin:0 0 10px;">Reference</p>
    <h1 style="font-size:clamp(28px,4vw,48px);font-weight:600;color:var(--color-text-1);letter-spacing:-0.035em;margin:0;">Documentation</h1>
  </div>

  <% if (docPages && docPages.length) { %>
  <div>
    <% docPages.forEach(function(doc) { %>
    <a href="<%= rootPrefix %>docs/<%= doc.slug %>/index.html"
      style="display:flex;align-items:flex-start;justify-content:space-between;gap:24px;padding:18px 0;border-bottom:1px solid var(--color-border);text-decoration:none;transition:padding-left 150ms;"
      onmouseover="this.style.paddingLeft='8px'" onmouseout="this.style.paddingLeft='0'">
      <div style="flex:1;min-width:0;">
        <h2 style="font-size:14px;font-weight:600;color:var(--color-text-1);letter-spacing:-0.01em;margin:0 0 4px;"><%= doc.title %></h2>
        <% if (doc.description) { %>
        <p style="font-size:12px;color:var(--color-text-3);margin:0;line-height:1.5;"><%= doc.description %></p>
        <% } %>
      </div>
      <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="color:var(--color-text-4);flex-shrink:0;margin-top:2px;"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </a>
    <% }) %>
  </div>
  <% } else { %>
  <p style="font-size:13px;font-family:var(--font-mono);color:var(--color-text-3);">No doc pages yet.</p>
  <% } %>

</div>

<script src="<%= rootPrefix %>public/js/main.js"></script>
</body>
</html>
