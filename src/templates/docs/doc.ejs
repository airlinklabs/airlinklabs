<%
const rootPrefix = '../../';
const pageTitle = 'Docs';
const pageDescription = currentDoc.description || site.description;
%>
<%- include('./partials/head', { site, underConstruction, rootPrefix, pageTitle, pageDescription }) %>
<%- include('./partials/nav', { site, underConstruction, rootPrefix, docPages, pageTitle }) %>

<div id="page-content" style="min-height:100vh;padding:clamp(32px,5vw,72px) clamp(72px,8vw,96px);box-sizing:border-box;max-width:820px;">

  <div style="padding:clamp(32px,6vw,80px) 0 clamp(20px,3vw,40px);border-bottom:1px solid var(--color-border);margin-bottom:clamp(24px,3vw,48px);">

    <!-- Doc nav row -->
    <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;margin-bottom:clamp(20px,3vw,36px);">
      <a href="<%= rootPrefix %>docs/index.html"
        style="display:inline-flex;align-items:center;gap:6px;font-size:11px;font-family:var(--font-mono);color:var(--color-text-3);text-decoration:none;"
        onmouseover="this.style.color='var(--color-text-1)'" onmouseout="this.style.color='var(--color-text-3)'">
        <svg width="10" height="10" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
        Docs
      </a>
      <% var currentIdx = docPages.findIndex(function(d) { return d.slug === currentDoc.slug; });
         var prev = currentIdx > 0 ? docPages[currentIdx - 1] : null;
         var next = currentIdx < docPages.length - 1 ? docPages[currentIdx + 1] : null;
      %>
      <% if (docPages.length > 1) { %>
      <span style="font-size:10px;color:var(--color-text-4);font-family:var(--font-mono);">/</span>
      <div style="display:flex;align-items:center;gap:4px;">
        <% docPages.forEach(function(doc) { %>
        <a href="<%= rootPrefix %>docs/<%= doc.slug %>/index.html"
          style="font-size:11px;font-family:var(--font-mono);color:<%= doc.slug === currentDoc.slug ? 'var(--color-text-1)' : 'var(--color-text-3)' %>;text-decoration:none;padding:2px 6px;border-radius:4px;background:<%= doc.slug === currentDoc.slug ? 'var(--color-bg-3)' : 'transparent' %>;"
          onmouseover="this.style.background='var(--color-bg-hover)'" onmouseout="this.style.background='<%= doc.slug === currentDoc.slug ? 'var(--color-bg-3)' : 'transparent' %>'">
          <%= doc.title %>
        </a>
        <% }) %>
      </div>
      <% } %>
    </div>

    <p style="font-size:10px;font-family:var(--font-mono);color:var(--color-text-3);text-transform:uppercase;letter-spacing:0.1em;margin:0 0 10px;">Documentation</p>
    <h1 style="font-size:clamp(22px,3.5vw,36px);font-weight:600;color:var(--color-text-1);letter-spacing:-0.03em;margin:0 0 12px;"><%= currentDoc.title %></h1>
    <% if (currentDoc.description) { %>
    <p style="font-size:14px;color:var(--color-text-3);line-height:1.65;margin:0 0 12px;"><%= currentDoc.description %></p>
    <% } %>
    <% if (currentDoc.author || currentDoc.date) { %>
    <div style="display:flex;align-items:center;gap:8px;font-size:11px;font-family:var(--font-mono);color:var(--color-text-4);">
      <% if (currentDoc.author) { %>
      <img src="https://github.com/<%= currentDoc.author %>.png?size=20" alt="" style="width:16px;height:16px;border-radius:50%;background:var(--color-bg-3);" onerror="this.style.display='none'">
      <span style="color:var(--color-text-3);"><%= currentDoc.author %></span>
      <% } %>
      <% if (currentDoc.date) { %>
      <% if (currentDoc.author) { %><span>·</span><% } %>
      <span><%= currentDoc.date %></span>
      <% } %>
    </div>
    <% } %>
  </div>

  <article class="prose">
    <%- currentDoc.content %>
  </article>

  <div style="display:flex;align-items:center;justify-content:space-between;margin-top:clamp(32px,4vw,56px);padding-top:24px;border-top:1px solid var(--color-border);">
    <% if (prev) { %>
    <a href="<%= rootPrefix %>docs/<%= prev.slug %>/index.html"
      style="display:flex;align-items:center;gap:7px;font-size:12px;color:var(--color-text-3);text-decoration:none;"
      onmouseover="this.style.color='var(--color-text-1)'" onmouseout="this.style.color='var(--color-text-3)'">
      <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
      <%= prev.title %>
    </a>
    <% } else { %><div></div><% } %>
    <% if (next) { %>
    <a href="<%= rootPrefix %>docs/<%= next.slug %>/index.html"
      style="display:flex;align-items:center;gap:7px;font-size:12px;color:var(--color-text-3);text-decoration:none;"
      onmouseover="this.style.color='var(--color-text-1)'" onmouseout="this.style.color='var(--color-text-3)'">
      <%= next.title %>
      <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </a>
    <% } else { %><div></div><% } %>
  </div>

</div>

<script src="<%= rootPrefix %>public/js/main.js"></script>
</body>
</html>
