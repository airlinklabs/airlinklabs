<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= pageTitle ? pageTitle + ' — ' + site.title : site.title + ' — ' + site.description.split('.')[0] %></title>
  <meta name="description" content="<%= pageDescription || site.description %>">
  <link rel="icon" href="<%= rootPrefix %>public/assets/favicon.ico" type="image/x-icon">
  <link rel="icon" href="<%= rootPrefix %>public/assets/icon.png"   type="image/png" sizes="any">

  <%
    var _siteUrl   = (site.siteUrl || '').replace(/\/$/, '');
    var _pageTitle = pageTitle ? pageTitle + ' — ' + site.title : site.title;
    var _pageDesc  = pageDescription || site.description;
    var _ogImage   = _siteUrl + '/public/assets/icon.png';
    // canonical: siteUrl + path derived from rootPrefix depth
    var _depth     = (rootPrefix.match(/\.\.\//g) || []).length;
    var _canonical = _siteUrl + (rootPrefix === '' ? '/' : ('/' + Array(_depth).fill('').join('')));
  %>

  <!-- Open Graph — used by Discord, GitHub, and most link previewers -->
  <meta property="og:type"        content="website">
  <meta property="og:site_name"   content="<%= site.title %>">
  <meta property="og:title"       content="<%= _pageTitle %>">
  <meta property="og:description" content="<%= _pageDesc %>">
  <meta property="og:image"       content="<%= _ogImage %>">
  <% if (_siteUrl) { %><meta property="og:url" content="<%= _canonical %>"><% } %>

  <link rel="preconnect" href="https://api.fontshare.com">
  <link href="https://api.fontshare.com/v2/css?f[]=general-sans@300,400,500,600,700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="<%= rootPrefix %>public/css/styles.css">

  <!-- Prevent theme flash — must run before first paint -->
  <script>
    (function () {
      var t = 'dark';
      try { t = localStorage.getItem('theme') || 'dark'; } catch (e) {}
      document.documentElement.className = t;
    })();
  </script>

  <% if (underConstruction && underConstruction.enabled) { %>
  <style>
    .uc-bar {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 9999;
      background: var(--color-warning);
      color: #000;
      font-size: 12px;
      font-family: var(--font-mono);
      text-align: center;
      padding: 6px 16px;
    }
  </style>
  <% } %>
</head>
<body>

<% if (underConstruction && underConstruction.enabled) { %>
<div class="uc-bar"><%= underConstruction.badge %>: <%= underConstruction.message %></div>
<% } %>

<!-- Loading screen -->
<div id="loading-screen">
  <div id="loading-inner">
    <img src="<%= rootPrefix %>public/assets/icon.png" alt="" width="32" height="32"
      onerror="this.style.display='none'">
    <span id="loading-title">AirLink</span>
  </div>
  <div id="loading-bar-wrap">
    <div id="loading-bar"></div>
  </div>
</div>

<script src="<%= rootPrefix %>public/js/sounds.js"></script>
