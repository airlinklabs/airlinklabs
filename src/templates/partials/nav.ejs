<%
var _page    = (pageTitle) ? String(pageTitle).toLowerCase() : 'home';
var _isHome  = (!pageTitle || _page === 'home' || _page === 'airlink');
var _active  = _isHome ? 'home' : _page;

var _links = [
  { key: 'home',     href: rootPrefix + 'index.html',          label: 'Home',     icon: 'M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z M9 22V12h6v10' },
  { key: 'docs',     href: rootPrefix + 'docs/index.html',     label: 'Docs',     icon: 'M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z M14 2v6h6 M16 13H8 M16 17H8 M10 9H8' },
  { key: 'registry', href: rootPrefix + 'registry/index.html', label: 'Registry', icon: 'M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z M3.27 6.96L12 12.01l8.73-5.05 M12 22.08V12' },
  { key: 'blog',     href: rootPrefix + 'blog/index.html',     label: 'Blog',     icon: 'M12 20h9 M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z' },
];
%>

<!-- Desktop: right pill strip (hidden on mobile via CSS) -->
<nav id="right-strip" aria-label="Site navigation">
  <% _links.forEach(function (link) { var on = link.key === _active; %>
  <a href="<%= link.href %>" title="<%= link.label %>"
    class="nav-strip-item <%= on ? 'nav-strip-item--active' : '' %>">
    <svg width="16" height="16" fill="none" stroke="currentColor"
      stroke-width="<%= on ? '2.2' : '1.7' %>" viewBox="0 0 24 24">
      <path d="<%= link.icon %>"/>
    </svg>
  </a>
  <% }); %>

  <div class="nav-divider"></div>

  <button data-theme-toggle title="Toggle theme" class="nav-strip-item">
    <svg class="theme-icon-sun"  width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" style="display:none;"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
    <svg class="theme-icon-moon" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" style="display:none;"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
  </button>

  <button id="mute-btn" title="Toggle sound" class="nav-strip-item">
    <svg class="mute-state-on"  width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/></svg>
    <svg class="mute-state-off" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" style="display:none;"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><line x1="23" y1="9" x2="17" y2="15"/><line x1="17" y1="9" x2="23" y2="15"/></svg>
  </button>
</nav>

<!-- Mobile: frosted glass pill (hidden on desktop via CSS) -->
<nav id="mobile-bar" aria-label="Site navigation">
  <% _links.forEach(function (link) { var on = link.key === _active; %>
  <a href="<%= link.href %>" class="mob-item <%= on ? 'mob-item--active' : '' %>">
    <svg width="18" height="18" fill="none" stroke="currentColor"
      stroke-width="<%= on ? '2.2' : '1.7' %>" viewBox="0 0 24 24">
      <path d="<%= link.icon %>"/>
    </svg>
    <span><%= link.label %></span>
  </a>
  <% }); %>

  <div class="mob-divider"></div>

  <button data-theme-toggle class="mob-item">
    <svg class="theme-icon-sun"  width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" style="display:none;"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
    <svg class="theme-icon-moon" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" style="display:none;"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
    <span>Theme</span>
  </button>

  <button id="mute-btn-mobile" class="mob-item">
    <svg class="mute-state-on"  width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/></svg>
    <svg class="mute-state-off" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" style="display:none;"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><line x1="23" y1="9" x2="17" y2="15"/><line x1="17" y1="9" x2="23" y2="15"/></svg>
    <span>Sound</span>
  </button>
</nav>

<% if (_isHome) { %>
<div id="credit-line">
  <span>MIT</span>
  <span class="credit-dot">·</span>
  <a href="https://github.com/thavanish" target="_blank" rel="noopener">Thavanish</a>
  <span class="credit-dot">·</span>
  <a href="https://github.com/<%= site.githubOrg %>" target="_blank" rel="noopener">AirlinkLabs</a>
</div>
<% } %>
