<%
var _navPage    = (pageTitle) ? String(pageTitle).toLowerCase() : 'home';
var _isHome     = (!pageTitle || _navPage === 'home' || _navPage === 'airlink');
var _activePage = _isHome ? 'home' : _navPage;

var _navLinks = [
  { key: 'home',     href: rootPrefix + 'index.html',          label: 'Home',     icon: 'M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z M9 22V12h6v10' },
  { key: 'docs',     href: rootPrefix + 'docs/index.html',     label: 'Docs',     icon: 'M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z M14 2v6h6 M16 13H8 M16 17H8' },
  { key: 'registry', href: rootPrefix + 'registry/index.html', label: 'Registry', icon: 'M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z' },
  { key: 'blog',     href: rootPrefix + 'blog/index.html',     label: 'Blog',     icon: 'M12 20h9 M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z' },
];
%>

<style>
  #right-strip      { display: flex; }
  #mobile-nav       { display: none; }

  @media (max-width: 600px) {
    #right-strip { display: none !important; }
    #mobile-nav  { display: flex; }
    .spa-section  { padding-right: clamp(16px,4vw,32px) !important; }
    #page-content { padding-right: clamp(16px,4vw,32px) !important; }
  }
</style>

<!-- Desktop right strip — pill-shaped, inset from edge -->
<div id="right-strip"
  style="position:fixed;right:10px;top:50%;transform:translateY(-50%);z-index:50;display:flex;flex-direction:column;align-items:center;gap:2px;background:var(--color-nav-bg);border:1px solid var(--color-border);border-radius:16px;padding:8px 0;box-shadow:0 4px 24px rgba(0,0,0,0.12);">

  <% _navLinks.forEach(function(link) { %>
  <% var isActive = link.key === _activePage; %>
  <a href="<%= link.href %>"
    title="<%= link.label %>"
    style="display:flex;align-items:center;justify-content:center;width:40px;height:40px;border-radius:10px;text-decoration:none;color:<%= isActive ? 'var(--color-text-1)' : 'var(--color-text-3)' %>;background:<%= isActive ? 'var(--color-bg-hover)' : 'transparent' %>;"
    onmouseover="this.style.color='var(--color-text-1)';this.style.background='var(--color-bg-hover)'"
    onmouseout="this.style.color='<%= isActive ? 'var(--color-text-1)' : 'var(--color-text-3)' %>';this.style.background='<%= isActive ? 'var(--color-bg-hover)' : 'transparent' %>'">
    <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="<%= isActive ? '2.2' : '1.7' %>" viewBox="0 0 24 24">
      <path d="<%= link.icon %>"/>
    </svg>
  </a>
  <% }) %>

  <div style="width:20px;height:1px;background:var(--color-border);margin:4px 0;flex-shrink:0;"></div>

  <button data-theme-toggle title="Toggle theme"
    style="display:flex;align-items:center;justify-content:center;width:40px;height:40px;border-radius:10px;background:transparent;border:none;cursor:pointer;color:var(--color-text-3);"
    onmouseover="this.style.color='var(--color-text-1)';this.style.background='var(--color-bg-hover)'"
    onmouseout="this.style.color='var(--color-text-3)';this.style.background='transparent'">
    <svg class="theme-icon-sun"  width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" style="display:none;"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
    <svg class="theme-icon-moon" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" style="display:none;"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
  </button>

  <button id="mute-btn" title="Toggle sound"
    style="display:flex;align-items:center;justify-content:center;width:40px;height:40px;border-radius:10px;background:transparent;border:none;cursor:pointer;color:var(--color-text-3);"
    onmouseover="this.style.color='var(--color-text-1)';this.style.background='var(--color-bg-hover)'"
    onmouseout="this.style.color='var(--color-text-3)';this.style.background='transparent'">
    <svg class="mute-state-on"  width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/></svg>
    <svg class="mute-state-off" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" style="display:none;"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><line x1="23" y1="9" x2="17" y2="15"/><line x1="17" y1="9" x2="23" y2="15"/></svg>
  </button>
</div>

<!-- Mobile floating nav -->
<div id="mobile-nav" style="position:fixed;bottom:20px;right:20px;z-index:50;flex-direction:column;align-items:flex-end;gap:8px;">

  <div id="mobile-nav-drawer"
    style="display:none;flex-direction:column;background:var(--color-nav-bg);border:1px solid var(--color-border);border-radius:16px;overflow:hidden;min-width:160px;box-shadow:0 8px 32px rgba(0,0,0,0.18);">
    <% _navLinks.forEach(function(link) { %>
    <% var isActive = link.key === _activePage; %>
    <a href="<%= link.href %>"
      style="display:flex;align-items:center;gap:10px;padding:11px 16px;font-size:13px;font-weight:<%= isActive ? '600' : '400' %>;color:<%= isActive ? 'var(--color-text-1)' : 'var(--color-text-2)' %>;text-decoration:none;border-bottom:1px solid var(--color-border);"
      onmouseover="this.style.background='var(--color-bg-hover)'" onmouseout="this.style.background=''">
      <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="<%= isActive ? '2.2' : '1.7' %>" viewBox="0 0 24 24"><path d="<%= link.icon %>"/></svg>
      <%= link.label %>
    </a>
    <% }) %>
    <div style="display:flex;">
      <button data-theme-toggle
        style="flex:1;display:flex;align-items:center;justify-content:center;padding:11px;background:transparent;border:none;border-right:1px solid var(--color-border);cursor:pointer;color:var(--color-text-3);"
        onmouseover="this.style.background='var(--color-bg-hover)'" onmouseout="this.style.background=''">
        <svg class="theme-icon-sun"  width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" style="display:none;"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
        <svg class="theme-icon-moon" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" style="display:none;"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
      </button>
      <button id="mute-btn-mobile"
        style="flex:1;display:flex;align-items:center;justify-content:center;padding:11px;background:transparent;border:none;cursor:pointer;color:var(--color-text-3);"
        onmouseover="this.style.background='var(--color-bg-hover)'" onmouseout="this.style.background=''">
        <svg class="mute-state-on"  width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/></svg>
        <svg class="mute-state-off" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" style="display:none;"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><line x1="23" y1="9" x2="17" y2="15"/><line x1="17" y1="9" x2="23" y2="15"/></svg>
      </button>
    </div>
  </div>

  <button id="mobile-nav-btn"
    style="width:44px;height:44px;border-radius:12px;border:1px solid var(--color-border);background:var(--color-nav-bg);color:var(--color-text-2);cursor:pointer;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 16px rgba(0,0,0,0.18);">
    <svg id="mobile-nav-icon-menu"  width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 12h18M3 6h18M3 18h18"/></svg>
    <svg id="mobile-nav-icon-close" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="display:none;"><path d="M18 6 6 18M6 6l12 12"/></svg>
  </button>
</div>

<% if (_isHome) { %>
<div id="credit-line" style="position:fixed;bottom:18px;left:20px;z-index:40;display:flex;align-items:center;gap:7px;">
  <span style="font-size:10px;font-family:var(--font-mono);color:var(--color-text-4);">MIT</span>
  <span style="font-size:10px;font-family:var(--font-mono);color:var(--color-text-4);">·</span>
  <a href="https://github.com/thavanish" target="_blank" rel="noopener" style="font-size:10px;font-family:var(--font-mono);color:var(--color-text-3);text-decoration:none;" onmouseover="this.style.color='var(--color-text-1)'" onmouseout="this.style.color='var(--color-text-3)'">Thavanish</a>
  <span style="font-size:10px;font-family:var(--font-mono);color:var(--color-text-4);">·</span>
  <a href="https://github.com/<%= site.githubOrg %>" target="_blank" rel="noopener" style="font-size:10px;font-family:var(--font-mono);color:var(--color-text-3);text-decoration:none;" onmouseover="this.style.color='var(--color-text-1)'" onmouseout="this.style.color='var(--color-text-3)'">AirlinkLabs</a>
</div>
<style>@media(max-width:600px){#credit-line{display:none;}}</style>
<% } %>

<script>
(function() {
  var btn    = document.getElementById('mobile-nav-btn');
  var drawer = document.getElementById('mobile-nav-drawer');
  var iconMenu  = document.getElementById('mobile-nav-icon-menu');
  var iconClose = document.getElementById('mobile-nav-icon-close');
  var muteBtn   = document.getElementById('mute-btn-mobile');
  if (!btn || !drawer) return;

  var open = false;
  function setOpen(val) {
    open = val;
    drawer.style.display    = open ? 'flex' : 'none';
    iconMenu.style.display  = open ? 'none' : '';
    iconClose.style.display = open ? '' : 'none';
    if (typeof sounds !== 'undefined') sounds.play(open ? 'drawerOpen' : 'drawerClose');
  }

  btn.addEventListener('click', function(e) {
    e.stopPropagation();
    setOpen(!open);
  });

  document.addEventListener('click', function(e) {
    if (!open) return;
    var nav = document.getElementById('mobile-nav');
    if (nav && !nav.contains(e.target)) setOpen(false);
  });

  if (muteBtn) {
    muteBtn.addEventListener('click', function() {
      if (typeof sounds !== 'undefined') sounds.toggle();
      var muted = typeof sounds !== 'undefined' && sounds.isMuted();
      document.querySelectorAll('.mute-state-on').forEach(function(el)  { el.style.display = muted ? 'none' : ''; });
      document.querySelectorAll('.mute-state-off').forEach(function(el) { el.style.display = muted ? '' : 'none'; });
    });
  }
})();
</script>
