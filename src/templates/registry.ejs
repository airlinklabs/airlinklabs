<%
const rootPrefix    = '../';
const pageTitle     = 'Registry';
const pageDescription = 'Community addons for AirLink Panel.';
%>
<%- include('./partials/head', { site, underConstruction, rootPrefix, pageTitle, pageDescription }) %>
<%- include('./partials/nav',  { site, underConstruction, rootPrefix, docPages, pageTitle }) %>

<div id="page-content">
  <div class="reg-wrap">

    <!-- Page header -->
    <header class="reg-header">
      <p class="reg-eyebrow">airlinklabs / addons</p>

      <div class="reg-header-row">
        <h1 class="reg-title">Registry</h1>

        <div class="reg-controls">
          <!-- Search -->
          <div class="reg-search-wrap">
            <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" class="reg-search-icon"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
            <input id="reg-search" type="text" placeholder="Search addons…" class="reg-search-input"
              onfocus="this.classList.add('focused')" onblur="this.classList.remove('focused')">
          </div>

          <!-- Filter dropdown -->
          <% if (addons && addons.length) {
               var allTags = [];
               addons.forEach(function (a) { (a.tags || []).forEach(function (t) { if (allTags.indexOf(t) === -1) allTags.push(t); }); });
               allTags.sort();
          %>
          <div id="reg-filter-wrap" class="reg-filter-wrap">
            <button id="reg-filter-btn" class="reg-filter-btn" aria-haspopup="listbox" aria-expanded="false">
              <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="4" y1="6" x2="20" y2="6"/><line x1="8" y1="12" x2="16" y2="12"/><line x1="11" y1="18" x2="13" y2="18"/></svg>
              <span id="reg-filter-label">All tags</span>
              <svg id="reg-filter-chevron" width="10" height="10" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="transition:transform 180ms;"><polyline points="6 9 12 15 18 9"/></svg>
            </button>

            <div id="reg-filter-menu" class="reg-filter-menu" role="listbox" style="display:none;">
              <button class="reg-filter-item" data-tag="all" role="option" style="font-weight:600;color:var(--color-text-1);">All tags</button>
              <% allTags.forEach(function (tag) { %>
              <button class="reg-filter-item" data-tag="<%= tag %>" role="option"><%= tag %></button>
              <% }); %>
            </div>
          </div>
          <% } %>

          <!-- Submit link -->
          <a href="https://github.com/<%= site.githubOrg %>/addons" target="_blank" rel="noopener" class="reg-submit-btn">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/></svg>
            Submit
          </a>
        </div>
      </div>
    </header>

    <!-- Addon list -->
    <% if (addons && addons.length) { %>
    <div id="addon-grid">
      <% addons.forEach(function (addon) { %>
      <div class="addon-card"
        data-name="<%= (addon.name || '').toLowerCase() %>"
        data-desc="<%= (addon.description || '').toLowerCase() %>"
        data-tags="<%= (addon.tags || []).join(',').toLowerCase() %>"
        data-addon='<%= JSON.stringify(addon).replace(/'/g, "&#39;") %>'>

        <div class="addon-card-left">
          <div class="addon-icon">
            <% if (addon.icon) { %>
            <img src="<%= addon.icon %>" alt=""
              loading="lazy"
              onerror="this.parentElement.innerHTML='<svg width=16 height=16 fill=none stroke=currentColor stroke-width=1.75 viewBox=&quot;0 0 24 24&quot; style=&quot;color:var(--color-text-3)&quot;><path d=&quot;M12 2l2 7h7l-5.5 4 2 7L12 16l-5.5 4 2-7L3 9h7z&quot;/></svg>'">
            <% } else { %>
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24" style="color:var(--color-text-3)"><path d="M12 2l2 7h7l-5.5 4 2 7L12 16l-5.5 4 2-7L3 9h7z"/></svg>
            <% } %>
          </div>

          <div class="addon-meta">
            <div class="addon-name-row">
              <span class="addon-name"><%= addon.name %></span>
              <span class="addon-author">by <%= addon.author %></span>
              <span class="addon-status addon-status--<%= addon.status || 'unknown' %>"><%= addon.status %></span>
            </div>
            <p class="addon-desc"><%= addon.description %></p>
            <div class="addon-tags">
              <% (addon.tags || []).forEach(function (tag) { %>
              <span class="addon-tag"><%= tag %></span>
              <% }); %>
            </div>
          </div>
        </div>

        <div class="addon-card-right">
          <span class="addon-version"><%= addon.version %></span>
          <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="color:var(--color-text-4);flex-shrink:0;"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </div>
      </div>
      <% }); %>
    </div>

    <div id="reg-empty" style="display:none;padding:48px 0;">
      <p style="font-size:13px;font-family:var(--font-mono);color:var(--color-text-3);margin:0;">No addons match.</p>
    </div>

    <% } else { %>
    <div style="padding:48px 0;border-bottom:1px solid var(--color-border);">
      <p style="font-size:13px;font-family:var(--font-mono);color:var(--color-text-3);margin:0 0 6px;">No addon data.</p>
      <p style="font-size:11px;font-family:var(--font-mono);color:var(--color-text-4);margin:0;">Run <code>npm run cache</code> to fetch from the registry.</p>
    </div>
    <% } %>

  </div>
</div>

<!-- Addon detail modal -->
<div id="addon-overlay">
  <div id="addon-modal">

    <!-- Modal header -->
    <div class="am-header">
      <div class="am-header-top">
        <div class="am-title-row">
          <div id="am-icon" class="am-icon"></div>
          <div>
            <div id="am-name" class="am-name"></div>
            <div id="am-byline" class="am-byline"></div>
          </div>
        </div>
        <button id="am-close" class="am-close" aria-label="Close">
          <svg width="10" height="10" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18 6 6 18M6 6l12 12"/></svg>
        </button>
      </div>

      <div class="am-actions">
        <a id="am-github" href="#" target="_blank" rel="noopener" class="am-btn am-btn--ghost">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/></svg>
          GitHub
        </a>
        <span id="am-status" class="am-status"></span>
        <button id="am-go-install" class="am-btn am-btn--primary">Install →</button>
      </div>
    </div>

    <!-- Tab bar -->
    <div class="am-tabs">
      <button class="addon-tab am-tab--active" data-tab="overview">Overview</button>
      <button class="addon-tab" data-tab="install">Installation</button>
    </div>

    <!-- Body -->
    <div class="am-body">
      <div class="addon-panel" data-panel="overview">
        <p id="am-desc" class="am-desc"></p>
        <div id="am-features"></div>
      </div>
      <div class="addon-panel" data-panel="install" style="display:none;">
        <div id="am-steps"></div>
        <div id="am-note" class="am-note" style="display:none;">
          <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="color:var(--color-text-3);flex-shrink:0;margin-top:1px;"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          <span id="am-note-text"></span>
        </div>
      </div>
    </div>

  </div>
</div>

<style>
/* ── Registry page layout ─────────────────────────────────────────────── */
.reg-wrap { max-width: 760px; }

.reg-header {
  padding: clamp(40px,7vw,96px) 0 clamp(24px,3vw,40px);
  border-bottom: 1px solid var(--color-border);
  margin-bottom: clamp(24px,3vw,40px);
}

.reg-eyebrow {
  font-size: 10px;
  font-family: var(--font-mono);
  color: var(--color-text-3);
  text-transform: uppercase;
  letter-spacing: 0.1em;
  margin: 0 0 10px;
}

.reg-header-row {
  display: flex;
  flex-wrap: wrap;
  align-items: flex-end;
  justify-content: space-between;
  gap: 16px;
}

.reg-title {
  font-size: clamp(28px,4vw,48px);
  font-weight: 600;
  color: var(--color-text-1);
  letter-spacing: -0.035em;
  margin: 0;
}

.reg-controls {
  display: flex;
  align-items: center;
  gap: 8px;
  flex-wrap: wrap;
}

/* Search */
.reg-search-wrap {
  position: relative;
}
.reg-search-icon {
  position: absolute;
  left: 10px;
  top: 50%;
  transform: translateY(-50%);
  color: var(--color-text-3);
  pointer-events: none;
}
.reg-search-input {
  background: var(--color-bg-2);
  border: 1px solid var(--color-border);
  border-radius: 999px;
  padding: 7px 12px 7px 30px;
  font-size: 12px;
  font-family: var(--font-mono);
  color: var(--color-text-1);
  outline: none;
  width: 180px;
}
.reg-search-input.focused { border-color: var(--color-border-input); }

/* Filter dropdown */
.reg-filter-wrap { position: relative; }

.reg-filter-btn {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 12px;
  font-family: var(--font-mono);
  color: var(--color-text-2);
  background: var(--color-bg-2);
  border: 1px solid var(--color-border);
  padding: 7px 12px;
  border-radius: 999px;
  cursor: pointer;
  white-space: nowrap;
}
.reg-filter-btn:hover { background: var(--color-bg-hover); border-color: var(--color-border-input); color: var(--color-text-1); }

.reg-filter-menu {
  position: absolute;
  top: calc(100% + 6px);
  left: 0;
  min-width: 160px;
  background: var(--color-bg-2);
  border: 1px solid var(--color-border);
  border-radius: 12px;
  padding: 4px;
  z-index: 100;
  box-shadow: 0 8px 24px rgba(0,0,0,0.24);
  transform-origin: top left;
}

.reg-filter-item {
  display: block;
  width: 100%;
  text-align: left;
  font-size: 12px;
  font-family: var(--font-mono);
  color: var(--color-text-2);
  background: transparent;
  border: none;
  padding: 8px 12px;
  border-radius: 8px;
  cursor: pointer;
  font-weight: 400;
}
.reg-filter-item:hover { background: var(--color-bg-hover); color: var(--color-text-1); }

/* Submit button */
.reg-submit-btn {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  font-size: 12px;
  font-weight: 500;
  color: var(--color-text-2);
  border: 1px solid var(--color-border);
  padding: 7px 16px;
  border-radius: 999px;
  white-space: nowrap;
}
.reg-submit-btn:hover { background: var(--color-bg-hover); color: var(--color-text-1); border-color: var(--color-border-input); }

/* Addon cards */
.addon-card {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24px;
  padding: 18px 0;
  border-bottom: 1px solid var(--color-border);
  cursor: pointer;
}
.addon-card:hover { padding-left: 8px; }

.addon-card-left {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  flex: 1;
  min-width: 0;
}

.addon-icon {
  width: 34px;
  height: 34px;
  border-radius: 9px;
  border: 1px solid var(--color-border);
  background: var(--color-bg-2);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  flex-shrink: 0;
  margin-top: 2px;
}
.addon-icon img { width: 100%; height: 100%; object-fit: contain; }

.addon-meta { flex: 1; min-width: 0; }

.addon-name-row {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 7px;
  margin-bottom: 4px;
}
.addon-name   { font-size: 15px; font-weight: 600; color: var(--color-text-1); letter-spacing: -0.015em; }
.addon-author { font-size: 10px; font-family: var(--font-mono); color: var(--color-text-3); }

.addon-status {
  font-size: 9px;
  font-family: var(--font-mono);
  padding: 2px 7px;
  border-radius: 999px;
  border: 1px solid;
}
.addon-status--working { color: var(--color-success); background: var(--color-success-bg); border-color: rgba(34,197,94,0.25); }
.addon-status--broken  { color: var(--color-danger);  background: var(--color-danger-bg);  border-color: rgba(239,68,68,0.25);  }
.addon-status--unknown { color: var(--color-warning); background: var(--color-warning-bg); border-color: rgba(245,158,11,0.25); }

.addon-desc  { font-size: 12px; color: var(--color-text-3); margin: 0 0 6px; line-height: 1.5; }

.addon-tags  { display: flex; flex-wrap: wrap; gap: 4px; }
.addon-tag   { font-size: 9px; font-family: var(--font-mono); color: var(--color-text-3); background: var(--color-bg-2); border: 1px solid var(--color-border); padding: 1px 8px; border-radius: 999px; }

.addon-card-right {
  display: flex;
  align-items: center;
  gap: 10px;
  flex-shrink: 0;
  padding-top: 2px;
}
.addon-version { font-size: 11px; font-family: var(--font-mono); color: var(--color-text-3); }

/* ── Addon modal ─────────────────────────────────────────────────────── */
#addon-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.55);
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20px;
  opacity: 0;
  pointer-events: none;
  transition: opacity 200ms cubic-bezier(0.4,0,0.2,1);
}

#addon-modal {
  background: var(--color-bg);
  border: 1px solid var(--color-border);
  border-radius: 14px;
  max-width: 620px;
  width: 100%;
  max-height: 85vh;
  overflow-y: auto;
  transform: translateY(10px) scale(0.98);
  transition: transform 220ms cubic-bezier(0.34,1.1,0.64,1);
}

.am-header {
  padding: clamp(20px,3vw,32px) clamp(20px,3vw,32px) clamp(14px,2vw,20px);
  border-bottom: 1px solid var(--color-border);
}

.am-header-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12px;
  margin-bottom: 14px;
}

.am-title-row {
  display: flex;
  align-items: center;
  gap: 12px;
}

.am-icon {
  width: 40px;
  height: 40px;
  border-radius: 10px;
  border: 1px solid var(--color-border);
  background: var(--color-bg-2);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  flex-shrink: 0;
}

.am-name   { font-size: clamp(16px,2.5vw,20px); font-weight: 600; color: var(--color-text-1); letter-spacing: -0.02em; line-height: 1.2; }
.am-byline { font-size: 11px; font-family: var(--font-mono); color: var(--color-text-3); margin-top: 3px; }

.am-close {
  width: 28px;
  height: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1px solid var(--color-border);
  border-radius: 8px;
  color: var(--color-text-3);
  background: transparent;
  cursor: pointer;
  flex-shrink: 0;
}
.am-close:hover { background: var(--color-bg-hover); }

.am-actions {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 8px;
}

.am-btn {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 12px;
  font-weight: 500;
  padding: 6px 16px;
  border-radius: 999px;
  cursor: pointer;
}
.am-btn--ghost {
  color: var(--color-text-2);
  border: 1px solid var(--color-border);
  background: transparent;
  text-decoration: none;
}
.am-btn--ghost:hover { background: var(--color-bg-hover); color: var(--color-text-1); border-color: var(--color-border-input); }
.am-btn--primary {
  background: var(--color-text-1);
  color: var(--color-bg);
  border: none;
}
.am-btn--primary:hover { opacity: 0.84; }

.am-status {
  font-size: 9px;
  font-family: var(--font-mono);
  padding: 3px 9px;
  border-radius: 999px;
  border: 1px solid;
}

.am-tabs {
  display: flex;
  gap: 2px;
  padding: 0 clamp(20px,3vw,32px);
  border-bottom: 1px solid var(--color-border);
}

.addon-tab {
  font-size: 12px;
  font-weight: 400;
  padding: 10px 14px;
  border: none;
  border-bottom: 2px solid transparent;
  color: var(--color-text-3);
  background: transparent;
  cursor: pointer;
}
.am-tab--active, .addon-tab:hover { color: var(--color-text-1); }
.am-tab--active { border-bottom-color: var(--color-text-1); font-weight: 600; }

.am-body { padding: clamp(18px,3vw,28px) clamp(20px,3vw,32px) clamp(22px,4vw,36px); }

.am-desc { font-size: 14px; color: var(--color-text-2); line-height: 1.75; margin: 0 0 18px; }

.am-note {
  margin-top: 16px;
  font-size: 12px;
  color: var(--color-text-2);
  background: var(--color-bg-2);
  border: 1px solid var(--color-border);
  border-radius: 10px;
  padding: 12px 14px;
  display: flex;
  align-items: flex-start;
  gap: 9px;
  line-height: 1.65;
}
</style>

<script src="<%= rootPrefix %>public/js/main.js"></script>
<script src="<%= rootPrefix %>public/js/registry.js"></script>

<script>
// Sync filter chevron rotation with menu state
(function () {
  var btn     = document.getElementById('reg-filter-btn');
  var chevron = document.getElementById('reg-filter-chevron');
  if (!btn || !chevron) return;

  var obs = new MutationObserver(function () {
    var expanded = btn.getAttribute('aria-expanded') === 'true';
    chevron.style.transform = expanded ? 'rotate(180deg)' : 'rotate(0deg)';
  });
  obs.observe(btn, { attributes: true, attributeFilter: ['aria-expanded'] });
})();
</script>

</body>
</html>
