<%
const rootPrefix = '../';
const pageTitle = 'Registry';
const pageDescription = 'Community addons for AirLink Panel.';
%>
<%- include('./partials/head', { site, underConstruction, rootPrefix, pageTitle, pageDescription }) %>
<%- include('./partials/nav', { site, underConstruction, rootPrefix, docPages, pageTitle }) %>

<div id="page-content" style="min-height:100vh;padding:clamp(32px,5vw,72px) clamp(72px,8vw,96px) clamp(32px,5vw,72px) clamp(20px,3vw,56px);box-sizing:border-box;overflow-x:hidden;">
  <div style="max-width:760px;">

  <!-- Header -->
  <div style="padding:clamp(40px,7vw,96px) 0 clamp(24px,3vw,48px);border-bottom:1px solid var(--color-border);margin-bottom:clamp(24px,3vw,48px);">
    <p style="font-size:10px;font-family:var(--font-mono);color:var(--color-text-3);text-transform:uppercase;letter-spacing:0.1em;margin:0 0 10px;">airlinklabs/addons</p>
    <div style="display:flex;flex-wrap:wrap;align-items:flex-end;justify-content:space-between;gap:16px;margin-bottom:clamp(16px,2vw,24px);">
      <h1 style="font-size:clamp(28px,4vw,48px);font-weight:600;color:var(--color-text-1);letter-spacing:-0.035em;margin:0;">Registry</h1>
      <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;">
        <div style="position:relative;">
          <svg style="position:absolute;left:10px;top:50%;transform:translateY(-50%);color:var(--color-text-3);pointer-events:none;" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
          <input id="reg-search" type="text" placeholder="Search addons…"
            style="background:var(--color-bg-2);border:1px solid var(--color-border);border-radius:999px;padding:7px 12px 7px 30px;font-size:12px;font-family:var(--font-mono);color:var(--color-text-1);outline:none;width:180px;"
            onfocus="this.style.borderColor='var(--color-border-input)'" onblur="this.style.borderColor='var(--color-border)'">
        </div>
        <a href="https://github.com/<%= site.githubOrg %>/addons" target="_blank" rel="noopener"
          style="display:inline-flex;align-items:center;gap:7px;font-size:12px;font-weight:500;color:var(--color-text-2);border:1px solid var(--color-border);padding:7px 16px;border-radius:999px;text-decoration:none;white-space:nowrap;"
          onmouseover="this.style.background='var(--color-bg-hover)';this.style.color='var(--color-text-1)';this.style.borderColor='var(--color-border-input)'"
          onmouseout="this.style.background='';this.style.color='var(--color-text-2)';this.style.borderColor='var(--color-border)'">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/></svg>
          Submit
        </a>
      </div>
    </div>
    <% if (addons && addons.length) { %>
    <%
      var allTags = [];
      addons.forEach(function(a){ (a.tags||[]).forEach(function(t){ if(allTags.indexOf(t)===-1) allTags.push(t); }); });
      allTags.sort();
    %>
    <div id="tag-filters" style="display:flex;flex-wrap:wrap;gap:6px;">
      <button class="tag-btn" data-tag="all"
        style="font-size:10px;font-family:var(--font-mono);color:var(--color-text-1);background:var(--color-bg-3);border:1px solid var(--color-border-input);padding:3px 12px;border-radius:999px;cursor:pointer;">All</button>
      <% allTags.forEach(function(tag){ %>
      <button class="tag-btn" data-tag="<%= tag %>"
        style="font-size:10px;font-family:var(--font-mono);color:var(--color-text-3);background:transparent;border:1px solid var(--color-border);padding:3px 12px;border-radius:999px;cursor:pointer;"
        onmouseover="if(!this.dataset.active){this.style.borderColor='var(--color-border-input)';this.style.color='var(--color-text-2)';}"
        onmouseout="if(!this.dataset.active){this.style.borderColor='var(--color-border)';this.style.color='var(--color-text-3)';}"><%= tag %></button>
      <% }) %>
    </div>
    <% } %>
  </div>

  <!-- Addon list -->
  <% if (addons && addons.length) { %>
  <div id="addon-grid">
    <% addons.forEach(function(addon){ %>
    <div class="addon-card"
      data-name="<%= (addon.name||'').toLowerCase() %>"
      data-desc="<%= (addon.description||'').toLowerCase() %>"
      data-tags="<%= (addon.tags||[]).join(',').toLowerCase() %>"
      data-addon='<%= JSON.stringify(addon).replace(/'/g,"&#39;") %>'
      style="display:flex;align-items:flex-start;justify-content:space-between;gap:24px;padding:20px 0;border-bottom:1px solid var(--color-border);cursor:pointer;transition:padding-left 150ms;"
      onmouseover="this.style.paddingLeft='8px'" onmouseout="this.style.paddingLeft='0'">

      <div style="display:flex;align-items:flex-start;gap:12px;flex:1;min-width:0;">
        <div style="width:34px;height:34px;border-radius:9px;border:1px solid var(--color-border);background:var(--color-bg-2);display:flex;align-items:center;justify-content:center;overflow:hidden;flex-shrink:0;margin-top:2px;">
          <% if (addon.icon) { %>
          <img src="<%= addon.icon %>" alt="" style="width:100%;height:100%;object-fit:contain;"
            onerror="this.parentElement.innerHTML='<svg width=\'14\' height=\'14\' fill=\'none\' stroke=\'currentColor\' stroke-width=\'2\' viewBox=\'0 0 24 24\' style=\'color:var(--color-text-3)\'><path d=\'M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z\'/></svg>'">
          <% } else { %>
          <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="color:var(--color-text-3);"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
          <% } %>
        </div>
        <div style="flex:1;min-width:0;">
          <div style="display:flex;flex-wrap:wrap;align-items:center;gap:7px;margin-bottom:4px;">
            <span style="font-size:15px;font-weight:600;color:var(--color-text-1);letter-spacing:-0.015em;"><%= addon.name %></span>
            <span style="font-size:10px;font-family:var(--font-mono);color:var(--color-text-3);">by <%= addon.author %></span>
            <span style="font-size:9px;font-family:var(--font-mono);padding:2px 7px;border-radius:999px;border:1px solid;
              <%= addon.status==='working'
                ? 'color:var(--color-success);background:var(--color-success-bg);border-color:rgba(34,197,94,0.25);'
                : addon.status==='broken'
                  ? 'color:var(--color-danger);background:var(--color-danger-bg);border-color:rgba(239,68,68,0.25);'
                  : 'color:var(--color-warning);background:var(--color-warning-bg);border-color:rgba(245,158,11,0.25);' %>">
              <%= addon.status %>
            </span>
          </div>
          <p style="font-size:12px;color:var(--color-text-3);margin:0 0 6px;line-height:1.5;"><%= addon.description %></p>
          <div style="display:flex;flex-wrap:wrap;gap:4px;">
            <% (addon.tags||[]).forEach(function(tag){ %>
            <span style="font-size:9px;font-family:var(--font-mono);color:var(--color-text-3);background:var(--color-bg-2);border:1px solid var(--color-border);padding:1px 8px;border-radius:999px;"><%= tag %></span>
            <% }) %>
          </div>
        </div>
      </div>

      <div style="display:flex;align-items:center;gap:10px;flex-shrink:0;padding-top:2px;">
        <span style="font-size:11px;font-family:var(--font-mono);color:var(--color-text-3);"><%= addon.version %></span>
        <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="color:var(--color-text-4);"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </div>
    </div>
    <% }) %>
  </div>

  <div id="reg-empty" style="display:none;padding:48px 0;">
    <p style="font-size:13px;font-family:var(--font-mono);color:var(--color-text-3);margin:0;">No addons match that filter.</p>
  </div>

  <% } else { %>
  <div style="padding:48px 0;border-bottom:1px solid var(--color-border);">
    <p style="font-size:13px;font-family:var(--font-mono);color:var(--color-text-3);margin:0 0 6px;">No addon data yet.</p>
    <p style="font-size:11px;font-family:var(--font-mono);color:var(--color-text-4);margin:0;">Run <code style="color:var(--color-text-2);background:var(--color-bg-3);padding:1px 6px;border-radius:4px;">npm run cache</code> to fetch from the registry.</p>
  </div>
  <% } %>

  </div>
</div>

<!-- Addon detail modal — blog post style -->
<div id="addon-overlay" style="position:fixed;inset:0;background:rgba(0,0,0,0.55);z-index:200;display:flex;align-items:center;justify-content:center;padding:20px;opacity:0;pointer-events:none;">
  <div id="addon-modal" style="background:var(--color-bg);border:1px solid var(--color-border);border-radius:14px;max-width:620px;width:100%;max-height:85vh;overflow-y:auto;transform:translateY(12px);">

    <!-- Header — like blog post header -->
    <div style="padding:clamp(24px,4vw,40px) clamp(20px,3vw,32px) clamp(16px,2vw,24px);border-bottom:1px solid var(--color-border);">
      <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:12px;margin-bottom:16px;">
        <div style="display:flex;align-items:center;gap:12px;">
          <div id="am-icon" style="width:40px;height:40px;border-radius:10px;border:1px solid var(--color-border);background:var(--color-bg-2);display:flex;align-items:center;justify-content:center;overflow:hidden;flex-shrink:0;"></div>
          <div>
            <div id="am-name" style="font-size:clamp(16px,2.5vw,20px);font-weight:600;color:var(--color-text-1);letter-spacing:-0.02em;line-height:1.2;"></div>
            <div id="am-byline" style="font-size:11px;font-family:var(--font-mono);color:var(--color-text-3);margin-top:3px;"></div>
          </div>
        </div>
        <button id="am-close"
          style="width:28px;height:28px;display:flex;align-items:center;justify-content:center;border:1px solid var(--color-border);border-radius:8px;color:var(--color-text-3);background:transparent;cursor:pointer;flex-shrink:0;"
          onmouseover="this.style.background='var(--color-bg-hover)'" onmouseout="this.style.background=''">
          <svg width="10" height="10" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18 6 6 18M6 6l12 12"/></svg>
        </button>
      </div>
      <div style="display:flex;flex-wrap:wrap;gap:8px;">
        <a id="am-github" href="#" target="_blank" rel="noopener"
          style="display:inline-flex;align-items:center;gap:6px;font-size:12px;font-weight:500;color:var(--color-text-2);border:1px solid var(--color-border);padding:6px 16px;border-radius:999px;text-decoration:none;"
          onmouseover="this.style.background='var(--color-bg-hover)';this.style.color='var(--color-text-1)';this.style.borderColor='var(--color-border-input)'"
          onmouseout="this.style.background='';this.style.color='var(--color-text-2)';this.style.borderColor='var(--color-border)'">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/></svg>
          GitHub
        </a>
        <button id="am-go-install"
          style="display:inline-flex;align-items:center;font-size:12px;font-weight:500;background:var(--color-text-1);color:var(--color-bg);padding:6px 16px;border-radius:999px;border:none;cursor:pointer;"
          onmouseover="this.style.opacity='0.82'" onmouseout="this.style.opacity='1'">
          Install →
        </button>
      </div>
    </div>

    <!-- Tab bar -->
    <div style="display:flex;gap:2px;padding:0 clamp(20px,3vw,32px);border-bottom:1px solid var(--color-border);">
      <button class="addon-tab" data-tab="overview"
        style="font-size:12px;font-weight:500;padding:10px 14px;border:none;border-bottom:2px solid var(--color-text-1);color:var(--color-text-1);background:transparent;cursor:pointer;">Overview</button>
      <button class="addon-tab" data-tab="install"
        style="font-size:12px;font-weight:500;padding:10px 14px;border:none;border-bottom:2px solid transparent;color:var(--color-text-3);background:transparent;cursor:pointer;">Installation</button>
    </div>

    <!-- Body — prose style matching blog posts -->
    <div style="padding:clamp(20px,3vw,32px) clamp(20px,3vw,32px) clamp(24px,4vw,40px);">
      <div class="addon-panel" data-panel="overview">
        <p id="am-desc" style="font-size:14px;color:var(--color-text-2);line-height:1.75;margin:0 0 20px;"></p>
        <div id="am-features"></div>
      </div>
      <div class="addon-panel" data-panel="install" style="display:none;">
        <div id="am-steps"></div>
        <div id="am-note" style="display:none;margin-top:16px;font-size:12px;color:var(--color-text-2);background:var(--color-bg-2);border:1px solid var(--color-border);border-radius:10px;padding:14px;align-items:flex-start;gap:9px;line-height:1.65;">
          <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="color:var(--color-text-3);flex-shrink:0;margin-top:1px;"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          <span id="am-note-text"></span>
        </div>
      </div>
    </div>

  </div>
</div>

<script src="<%= rootPrefix %>public/js/main.js"></script>
<script src="<%= rootPrefix %>public/js/registry.js"></script>
</body>
</html>
